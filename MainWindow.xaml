<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="sumi.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:sumi"
    Title="sumi">

    <Window.SystemBackdrop>
        <DesktopAcrylicBackdrop />
    </Window.SystemBackdrop>

    <!-- 微細なデスクトップ壁紙透過を活かすため半透明の深炭色背景を設定 -->
    <Grid x:Name="RootGrid" Background="#ee141414">
        <Grid.Resources>
            <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            
            <!-- ボタンのポインターホバー・プレス時の背景・フォアグラウンドカラーをオーバーライド -->
            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#2d2d2d" />
            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#3d3d3d" />
            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#ffffff" />
            <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#cccccc" />
            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent" />
            <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent" />
            <SolidColorBrush x:Key="ButtonBackgroundDisabled" Color="Transparent" />
            <SolidColorBrush x:Key="ButtonForegroundDisabled" Color="#444444" />

            <!-- トグルボタンの背景・フォアグラウンドカラーをオーバーライド -->
            <SolidColorBrush x:Key="ToggleButtonBackgroundChecked" Color="#444444" />
            <SolidColorBrush x:Key="ToggleButtonBackgroundCheckedPointerOver" Color="#555555" />
            <SolidColorBrush x:Key="ToggleButtonBackgroundCheckedPressed" Color="#666666" />
            <SolidColorBrush x:Key="ToggleButtonForegroundChecked" Color="#ffffff" />
            <SolidColorBrush x:Key="ToggleButtonForegroundCheckedPointerOver" Color="#ffffff" />
            <SolidColorBrush x:Key="ToggleButtonForegroundCheckedPressed" Color="#ffffff" />
            <SolidColorBrush x:Key="ToggleButtonBorderBrushChecked" Color="Transparent" />
            
            <SolidColorBrush x:Key="ToggleButtonBackgroundPointerOver" Color="#2d2d2d" />
            <SolidColorBrush x:Key="ToggleButtonBackgroundPressed" Color="#3d3d3d" />
            <SolidColorBrush x:Key="ToggleButtonForegroundPointerOver" Color="#ffffff" />
            <SolidColorBrush x:Key="ToggleButtonForegroundPressed" Color="#cccccc" />
            <SolidColorBrush x:Key="ToggleButtonBorderBrushPointerOver" Color="Transparent" />
            <SolidColorBrush x:Key="ToggleButtonBorderBrushPressed" Color="Transparent" />
            <SolidColorBrush x:Key="ToggleButtonBackgroundDisabled" Color="Transparent" />
            <SolidColorBrush x:Key="ToggleButtonForegroundDisabled" Color="#444444" />

            <!-- ヘッダーおよびステータスバーの共通ボタン用スタイル -->
            <Style x:Key="IconButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="#002D2D2D" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="CornerRadius" Value="4" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Width" Value="32" />
                <Setter Property="Height" Value="32" />
                <Setter Property="Foreground" Value="#cccccc" />
                <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
                <Setter Property="FontSize" Value="14" />
            </Style>

            <Style x:Key="IconToggleButtonStyle" TargetType="ToggleButton">
                <Setter Property="Background" Value="#002D2D2D" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="CornerRadius" Value="4" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Width" Value="32" />
                <Setter Property="Height" Value="32" />
                <Setter Property="Foreground" Value="#cccccc" />
                <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
                <Setter Property="FontSize" Value="14" />
            </Style>


            <!-- メモアイテムの表示テンプレート -->
            <DataTemplate x:Key="NoteItemTemplate" x:DataType="local:NoteItemViewModel">
                <Grid Padding="0" Background="{x:Bind BackgroundBrush, Mode=OneTime}" CornerRadius="4" 
                      PointerEntered="NoteItemGrid_PointerEntered" 
                      PointerExited="NoteItemGrid_PointerExited">

                    <!-- メモ選択領域 (横いっぱいに広げ、ホバー時にのみ右側のアクションボタン用の隙間を動的に空ける) -->
                    <Button x:Name="NoteButton"
                            HorizontalAlignment="Stretch" 
                            HorizontalContentAlignment="Stretch" 
                            Background="#002D2D2D" 
                            BorderThickness="0"
                            Padding="12,10,12,10"
                            CornerRadius="4"
                            Loaded="NoteItemButton_Loaded"
                            Unloaded="NoteItemButton_Unloaded">
                        <Grid RowSpacing="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="{x:Bind Title}" FontSize="13" FontWeight="SemiBold" Foreground="#ffffff" TextTrimming="CharacterEllipsis" MaxLines="1" HorizontalAlignment="Stretch" />
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="4">
                                <Ellipse Width="6" Height="6" Fill="#4CAF50" VerticalAlignment="Center" Margin="0,1,0,0" Visibility="{x:Bind CurrentIndicatorVisibility}" />
                                <TextBlock Text="{x:Bind Subtitle}" FontSize="11" Foreground="#999999" VerticalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </Button>

                    <!-- アクション領域（ホバー時にのみ表示。右上に重ねて表示する） -->
                    <StackPanel x:Name="ActionsPanel" 
                                HorizontalAlignment="Right" 
                                Orientation="Horizontal" 
                                VerticalAlignment="Center" 
                                Spacing="2" 
                                Padding="8,0,8,0" 
                                Visibility="Collapsed">
                        <Button Style="{StaticResource IconButtonStyle}" 
                                Width="28" Height="28"
                                ToolTipService.ToolTip="{x:Bind PinToolTip}"
                                Loaded="PinItemButton_Loaded"
                                Unloaded="PinItemButton_Unloaded">
                            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                <!-- Base outline pin (always visible, draws the needle) -->
                                <FontIcon Glyph="&#xE718;" 
                                          FontFamily="Segoe Fluent Icons" 
                                          FontSize="12"
                                          Foreground="{x:Bind PinForeground}" />
                                <!-- Filled pin overlay (only visible when pinned, fills the head) -->
                                <FontIcon Glyph="&#xE841;" 
                                          FontFamily="Segoe Fluent Icons" 
                                          FontSize="12"
                                          Foreground="{x:Bind PinForeground}"
                                          Visibility="{x:Bind PinnedFillVisibility}" />
                            </Grid>
                        </Button>
                        <Button Content="&#xE74D;" 
                                Style="{StaticResource IconButtonStyle}" 
                                Width="28" Height="28" FontSize="11"
                                ToolTipService.ToolTip="削除"
                                Visibility="{x:Bind DeleteButtonVisibility}"
                                Loaded="DeleteItemButton_Loaded"
                                Unloaded="DeleteItemButton_Unloaded" />
                    </StackPanel>
                </Grid>
            </DataTemplate>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- タイトルバー -->
            <RowDefinition Height="*" />    <!-- エディットエリア -->
            <RowDefinition Height="Auto" /> <!-- ステータスバー -->
        </Grid.RowDefinitions>

        <!-- 1. カスタムタイトルバー -->
        <Grid Grid.Row="0" Height="36" BorderBrush="#2d2d2d" BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" /> <!-- 左側操作ボタン群 -->
                <ColumnDefinition Width="*" />    <!-- 中央ドラッグ領域 (タイトル) -->
                <ColumnDefinition Width="Auto" /> <!-- 右側システムボタン用プレースホルダー -->
            </Grid.ColumnDefinitions>

            <!-- 操作ボタン群 (ドラッグ無効) -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0" Spacing="4">
                <!-- 設定ボタン -->
                <Button x:Name="PlayButton" Content="&#xE713;" Style="{StaticResource IconButtonStyle}" ToolTipService.ToolTip="設定">
                    <Button.Flyout>
                        <Flyout x:Name="SettingsFlyout" Placement="BottomEdgeAlignedLeft" Opened="SettingsFlyout_Opened">
                            <Flyout.FlyoutPresenterStyle>
                                <Style TargetType="FlyoutPresenter">
                                    <Setter Property="Background" Value="{StaticResource OpaqueFlyoutBackgroundBrush}" />
                                    <Setter Property="BorderBrush" Value="#333333" />
                                    <Setter Property="BorderThickness" Value="1" />
                                    <Setter Property="CornerRadius" Value="8" />
                                    <Setter Property="Padding" Value="12" />
                                    <Setter Property="MaxWidth" Value="340" />
                                    <Setter Property="MinWidth" Value="300" />
                                    <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled" />
                                    <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
                                </Style>
                            </Flyout.FlyoutPresenterStyle>
                            
                            <Grid RowSpacing="8" Width="300">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" /> <!-- 検索ボックス -->
                                    <RowDefinition Height="Auto" /> <!-- タブ切り替え SelectorBar -->
                                    <RowDefinition Height="*" />    <!-- 設定項目リスト -->
                                </Grid.RowDefinitions>
                                
                                <TextBox x:Name="SettingsSearchBox" 
                                         Grid.Row="0"
                                         PlaceholderText="Search for settings..."
                                         TextChanged="SettingsSearchBox_TextChanged">
                                    <TextBox.Resources>
                                        <SolidColorBrush x:Key="TextControlBackground" Color="#252525" />
                                        <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#2d2d2d" />
                                        <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#2d2d2d" />
                                        <SolidColorBrush x:Key="TextControlBorderBrush" Color="#333333" />
                                        <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#444444" />
                                        <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#0078d4" />
                                        <SolidColorBrush x:Key="TextControlForeground" Color="#ffffff" />
                                        <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="#ffffff" />
                                        <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#ffffff" />
                                        <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#777777" />
                                        <SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver" Color="#777777" />
                                        <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="#777777" />
                                    </TextBox.Resources>
                                </TextBox>

                                <!-- タブ選択バー -->
                                <SelectorBar x:Name="SettingsSelectorBar" 
                                             Grid.Row="1" 
                                             SelectionChanged="SettingsSelectorBar_SelectionChanged" 
                                             Margin="0,0,0,4" 
                                             HorizontalAlignment="Stretch">
                                    <SelectorBarItem x:Name="EditorTab" Text="Editor" IsSelected="True">
                                        <SelectorBarItem.Icon>
                                            <FontIcon Glyph="&#xE8D2;" />
                                        </SelectorBarItem.Icon>
                                    </SelectorBarItem>
                                    <SelectorBarItem x:Name="WindowTab" Text="Window">
                                        <SelectorBarItem.Icon>
                                            <FontIcon Glyph="&#xE7B5;" />
                                        </SelectorBarItem.Icon>
                                    </SelectorBarItem>
                                    <SelectorBarItem x:Name="SystemTab" Text="System">
                                        <SelectorBarItem.Icon>
                                            <FontIcon Glyph="&#xE765;" />
                                        </SelectorBarItem.Icon>
                                    </SelectorBarItem>
                                </SelectorBar>
                                
                                <ScrollViewer x:Name="SettingsScrollViewer" Grid.Row="2" MaxHeight="320" VerticalScrollBarVisibility="Auto">
                                    <Grid>
                                        <!-- エディタ設定カテゴリ -->
                                        <StackPanel x:Name="EditorSettingsPanel" Spacing="4" Visibility="Visible">
                                            <!-- フォント -->
                                            <Grid x:Name="FontItem" Padding="6,6" CornerRadius="4" Background="Transparent"
                                                  PointerEntered="SettingItem_PointerEntered" PointerExited="SettingItem_PointerExited">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="&#xE8D2;" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#cccccc" VerticalAlignment="Center" Margin="4,0,10,0" />
                                                <TextBlock Grid.Column="1" Text="Font" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center" />
                                                <ComboBox Grid.Column="2" x:Name="FontComboBox" FontSize="12" Height="28" Padding="8,0,24,0" SelectionChanged="FontComboBox_SelectionChanged" BorderThickness="1" BorderBrush="#333333" Background="#252525" CornerRadius="4">
                                                    <x:String>Noto Sans JP</x:String>
                                                    <x:String>Yu Gothic UI</x:String>
                                                    <x:String>Segoe UI</x:String>
                                                    <x:String>Consolas</x:String>
                                                    <x:String>Georgia</x:String>
                                                </ComboBox>
                                            </Grid>

                                            <!-- フォントウェイト -->
                                            <Grid x:Name="FontWeightItem" Padding="6,6" CornerRadius="4" Background="Transparent"
                                                  PointerEntered="SettingItem_PointerEntered" PointerExited="SettingItem_PointerExited">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="&#xE19B;" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#cccccc" VerticalAlignment="Center" Margin="4,0,10,0" />
                                                <TextBlock Grid.Column="1" Text="Font Weight" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center" />
                                                <ComboBox Grid.Column="2" x:Name="FontWeightComboBox" FontSize="12" Height="28" Padding="8,0,24,0" SelectionChanged="FontWeightComboBox_SelectionChanged" BorderThickness="1" BorderBrush="#333333" Background="#252525" CornerRadius="4">
                                                    <x:String>Light</x:String>
                                                    <x:String>Normal</x:String>
                                                    <x:String>Medium</x:String>
                                                    <x:String>SemiBold</x:String>
                                                    <x:String>Bold</x:String>
                                                </ComboBox>
                                            </Grid>
                                            
                                            <!-- フォントサイズ -->
                                            <Grid x:Name="FontSizeItem" Padding="6,6" CornerRadius="4" Background="Transparent"
                                                  PointerEntered="SettingItem_PointerEntered" PointerExited="SettingItem_PointerExited">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="&#xE8E9;" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#cccccc" VerticalAlignment="Center" Margin="4,0,10,0" />
                                                <TextBlock Grid.Column="1" Text="Font Size" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center" />
                                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                                    <Button x:Name="FontSizeDecreaseButton" Content="&#xE108;" Style="{StaticResource IconButtonStyle}" Width="24" Height="24" FontSize="10" Click="FontSizeDecreaseButton_Click" VerticalAlignment="Center" />
                                                    <Slider x:Name="FontSizeSlider" Minimum="10" Maximum="36" StepFrequency="0.5" Width="72" Margin="0,-6,0,-6" ValueChanged="FontSizeSlider_ValueChanged" />
                                                    <Button x:Name="FontSizeIncreaseButton" Content="&#xE109;" Style="{StaticResource IconButtonStyle}" Width="24" Height="24" FontSize="10" Click="FontSizeIncreaseButton_Click" VerticalAlignment="Center" />
                                                    <TextBlock x:Name="FontSizeValueText" Text="14.0" FontSize="12" Foreground="#999999" Width="28" TextAlignment="Right" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Grid>
                                            
                                            <!-- 行間 -->
                                            <Grid x:Name="LineSpacingItem" Padding="6,6" CornerRadius="4" Background="Transparent"
                                                  PointerEntered="SettingItem_PointerEntered" PointerExited="SettingItem_PointerExited">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="&#xE8A7;" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#cccccc" VerticalAlignment="Center" Margin="4,0,10,0" />
                                                <TextBlock Grid.Column="1" Text="Line Spacing" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center" />
                                                <ComboBox Grid.Column="2" x:Name="LineSpacingComboBox" 
                                                          IsEditable="True" 
                                                          FontSize="12" Height="28" Padding="8,0,24,0" 
                                                          SelectionChanged="LineSpacingComboBox_SelectionChanged" 
                                                          LostFocus="LineSpacingComboBox_LostFocus"
                                                          BorderThickness="1" BorderBrush="#333333" Background="#252525" CornerRadius="4">
                                                    <x:String>0.8</x:String>
                                                    <x:String>0.85</x:String>
                                                    <x:String>0.9</x:String>
                                                    <x:String>0.95</x:String>
                                                    <x:String>1.0</x:String>
                                                </ComboBox>
                                            </Grid>
                                            
                                            <!-- 段落スペース -->
                                            <Grid x:Name="ParagraphSpacingItem" Padding="6,6" CornerRadius="4" Background="Transparent"
                                                  PointerEntered="SettingItem_PointerEntered" PointerExited="SettingItem_PointerExited">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="&#xE8A5;" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#cccccc" VerticalAlignment="Center" Margin="4,0,10,0" />
                                                <TextBlock Grid.Column="1" Text="Paragraph Spacing" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center" />
                                                <ComboBox Grid.Column="2" x:Name="ParagraphSpacingComboBox" 
                                                          IsEditable="True" 
                                                          FontSize="12" Height="28" Padding="8,0,24,0" 
                                                          SelectionChanged="ParagraphSpacingComboBox_SelectionChanged" 
                                                          LostFocus="ParagraphSpacingComboBox_LostFocus"
                                                          BorderThickness="1" BorderBrush="#333333" Background="#252525" CornerRadius="4">
                                                    <x:String>0</x:String>
                                                    <x:String>2</x:String>
                                                    <x:String>4</x:String>
                                                    <x:String>6</x:String>
                                                    <x:String>8</x:String>
                                                    <x:String>10</x:String>
                                                    <x:String>12</x:String>
                                                </ComboBox>
                                            </Grid>
                                        </StackPanel>

                                        <!-- ウィンドウ設定カテゴリ -->
                                        <StackPanel x:Name="WindowSettingsPanel" Spacing="4" Visibility="Collapsed">
                                            <!-- 不透明度 -->
                                            <Grid x:Name="OpacityItem" Padding="6,6" CornerRadius="4" Background="Transparent"
                                                  PointerEntered="SettingItem_PointerEntered" PointerExited="SettingItem_PointerExited">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="&#xE7B3;" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#cccccc" VerticalAlignment="Center" Margin="4,0,10,0" />
                                                <TextBlock Grid.Column="1" Text="Opacity" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center" />
                                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                                    <Button x:Name="OpacityDecreaseButton" Content="&#xE108;" Style="{StaticResource IconButtonStyle}" Width="24" Height="24" FontSize="10" Click="OpacityDecreaseButton_Click" VerticalAlignment="Center" />
                                                    <Slider x:Name="OpacitySlider" Minimum="0" Maximum="100" StepFrequency="1" Width="72" Margin="0,-6,0,-6" ValueChanged="OpacitySlider_ValueChanged" />
                                                    <Button x:Name="OpacityIncreaseButton" Content="&#xE109;" Style="{StaticResource IconButtonStyle}" Width="24" Height="24" FontSize="10" Click="OpacityIncreaseButton_Click" VerticalAlignment="Center" />
                                                    <TextBlock x:Name="OpacityValueText" Text="20%" FontSize="12" Foreground="#999999" Width="28" TextAlignment="Right" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Grid>
                                            
                                            <!-- 削除ボタンの表示 -->
                                            <Grid x:Name="ShowDeleteButtonItem" Padding="6,6" CornerRadius="4" Background="Transparent"
                                                  PointerEntered="SettingItem_PointerEntered" PointerExited="SettingItem_PointerExited">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="&#xE74D;" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#cccccc" VerticalAlignment="Center" Margin="4,0,10,0" />
                                                <TextBlock Grid.Column="1" Text="Show Delete Button" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center" />
                                                <ToggleSwitch Grid.Column="2" x:Name="ShowDeleteButtonToggle" OnContent="" OffContent="" MinWidth="0" VerticalAlignment="Center" Toggled="ShowDeleteButtonToggle_Toggled" />
                                            </Grid>

                                            <!-- 直近メモ表示件数 -->
                                            <Grid x:Name="RecentNotesCountItem" Padding="6,6" CornerRadius="4" Background="Transparent"
                                                  PointerEntered="SettingItem_PointerEntered" PointerExited="SettingItem_PointerExited">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="&#xE81C;" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#cccccc" VerticalAlignment="Center" Margin="4,0,10,0" />
                                                <TextBlock Grid.Column="1" Text="Recent Notes Count" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center" />
                                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                                    <Button x:Name="RecentNotesCountDecreaseButton" Content="&#xE108;" Style="{StaticResource IconButtonStyle}" Width="24" Height="24" FontSize="10" Click="RecentNotesCountDecreaseButton_Click" VerticalAlignment="Center" />
                                                    <Slider x:Name="RecentNotesCountSlider" Minimum="0" Maximum="10" StepFrequency="1" Width="72" Margin="0,-6,0,-6" ValueChanged="RecentNotesCountSlider_ValueChanged" />
                                                    <Button x:Name="RecentNotesCountIncreaseButton" Content="&#xE109;" Style="{StaticResource IconButtonStyle}" Width="24" Height="24" FontSize="10" Click="RecentNotesCountIncreaseButton_Click" VerticalAlignment="Center" />
                                                    <TextBlock x:Name="RecentNotesCountValueText" Text="1" FontSize="12" Foreground="#999999" Width="28" TextAlignment="Right" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                        
                                        <!-- システム設定カテゴリ -->
                                        <StackPanel x:Name="SystemSettingsPanel" Spacing="4" Visibility="Collapsed">
                                            <!-- 起動ホットキー -->
                                            <Grid x:Name="LaunchHotKeyItem" Padding="6,6" CornerRadius="4" Background="Transparent"
                                                  PointerEntered="SettingItem_PointerEntered" PointerExited="SettingItem_PointerExited">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="&#xE765;" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#cccccc" VerticalAlignment="Center" Margin="4,0,10,0" />
                                                <TextBlock Grid.Column="1" Text="Launch Hotkey" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center" />
                                                <Button Grid.Column="2" x:Name="LaunchHotKeyButton" Width="100" Height="28" Padding="8,0" FontSize="12"
                                                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                        BorderThickness="1" BorderBrush="#333333" Background="#252525" Foreground="#ffffff" CornerRadius="4">
                                                    <Button.Resources>
                                                        <SolidColorBrush x:Key="ButtonBackground" Color="#252525" />
                                                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#2d2d2d" />
                                                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#3d3d3d" />
                                                        <SolidColorBrush x:Key="ButtonBorderBrush" Color="#333333" />
                                                        <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#444444" />
                                                        <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#0078d4" />
                                                        <SolidColorBrush x:Key="ButtonForeground" Color="#ffffff" />
                                                        <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#ffffff" />
                                                        <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#ffffff" />
                                                    </Button.Resources>
                                                    <Button.Flyout>
                                                        <Flyout x:Name="LaunchHotKeyFlyout" Opened="HotKeyFlyout_Opened" Closed="HotKeyFlyout_Closed">
                                                            <Flyout.FlyoutPresenterStyle>
                                                                <Style TargetType="FlyoutPresenter">
                                                                    <Setter Property="Background" Value="{StaticResource FlyoutBackgroundBrush}" />
                                                                    <Setter Property="BorderBrush" Value="#333333" />
                                                                    <Setter Property="BorderThickness" Value="1" />
                                                                    <Setter Property="CornerRadius" Value="8" />
                                                                    <Setter Property="Padding" Value="10" />
                                                                </Style>
                                                            </Flyout.FlyoutPresenterStyle>
                                                            <StackPanel Spacing="8" Width="180">
                                                                <TextBlock Text="Press key combination:" FontSize="11" Foreground="#cccccc" />
                                                                <TextBox x:Name="LaunchHotKeyInput" Height="28" IsReadOnly="True" KeyDown="HotKeyInput_KeyDown" TextAlignment="Center" FontSize="12" VerticalContentAlignment="Center" Background="#252525" BorderThickness="1" BorderBrush="#333333" CornerRadius="4">
                                                                    <TextBox.Resources>
                                                                        <SolidColorBrush x:Key="TextControlBackground" Color="#252525" />
                                                                        <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#2d2d2d" />
                                                                        <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#2d2d2d" />
                                                                        <SolidColorBrush x:Key="TextControlBorderBrush" Color="#333333" />
                                                                        <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#444444" />
                                                                        <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#0078d4" />
                                                                        <SolidColorBrush x:Key="TextControlForeground" Color="#ffffff" />
                                                                    </TextBox.Resources>
                                                                </TextBox>
                                                                <Grid ColumnSpacing="4">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="*" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <Button Grid.Column="0" Content="Save" Click="SaveLaunchHotKey_Click" HorizontalAlignment="Stretch" Height="24" Padding="0" FontSize="11" CornerRadius="4" />
                                                                    <Button Grid.Column="1" Content="Clear" Click="ClearLaunchHotKey_Click" HorizontalAlignment="Stretch" Height="24" Padding="0" FontSize="11" CornerRadius="4" />
                                                                    <Button Grid.Column="2" Content="Cancel" Click="CancelLaunchHotKey_Click" HorizontalAlignment="Stretch" Height="24" Padding="0" FontSize="11" CornerRadius="4" />
                                                                </Grid>
                                                            </StackPanel>
                                                        </Flyout>
                                                    </Button.Flyout>
                                                </Button>
                                            </Grid>

                                            <!-- 終了ホットキー -->
                                            <Grid x:Name="QuitHotKeyItem" Padding="6,6" CornerRadius="4" Background="Transparent"
                                                  PointerEntered="SettingItem_PointerEntered" PointerExited="SettingItem_PointerExited">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="&#xE106;" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#cccccc" VerticalAlignment="Center" Margin="4,0,10,0" />
                                                <TextBlock Grid.Column="1" Text="Quit Hotkey" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center" />
                                                <Button Grid.Column="2" x:Name="QuitHotKeyButton" Width="100" Height="28" Padding="8,0" FontSize="12"
                                                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                        BorderThickness="1" BorderBrush="#333333" Background="#252525" Foreground="#ffffff" CornerRadius="4">
                                                    <Button.Resources>
                                                        <SolidColorBrush x:Key="ButtonBackground" Color="#252525" />
                                                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#2d2d2d" />
                                                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#3d3d3d" />
                                                        <SolidColorBrush x:Key="ButtonBorderBrush" Color="#333333" />
                                                        <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#444444" />
                                                        <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#0078d4" />
                                                        <SolidColorBrush x:Key="ButtonForeground" Color="#ffffff" />
                                                        <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#ffffff" />
                                                        <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#ffffff" />
                                                    </Button.Resources>
                                                    <Button.Flyout>
                                                        <Flyout x:Name="QuitHotKeyFlyout" Opened="HotKeyFlyout_Opened" Closed="HotKeyFlyout_Closed">
                                                            <Flyout.FlyoutPresenterStyle>
                                                                <Style TargetType="FlyoutPresenter">
                                                                    <Setter Property="Background" Value="{StaticResource FlyoutBackgroundBrush}" />
                                                                    <Setter Property="BorderBrush" Value="#333333" />
                                                                    <Setter Property="BorderThickness" Value="1" />
                                                                    <Setter Property="CornerRadius" Value="8" />
                                                                    <Setter Property="Padding" Value="10" />
                                                                </Style>
                                                            </Flyout.FlyoutPresenterStyle>
                                                            <StackPanel Spacing="8" Width="180">
                                                                <TextBlock Text="Press key combination:" FontSize="11" Foreground="#cccccc" />
                                                                <TextBox x:Name="QuitHotKeyInput" Height="28" IsReadOnly="True" KeyDown="HotKeyInput_KeyDown" TextAlignment="Center" FontSize="12" VerticalContentAlignment="Center" Background="#252525" BorderThickness="1" BorderBrush="#333333" CornerRadius="4">
                                                                    <TextBox.Resources>
                                                                        <SolidColorBrush x:Key="TextControlBackground" Color="#252525" />
                                                                        <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#2d2d2d" />
                                                                        <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#2d2d2d" />
                                                                        <SolidColorBrush x:Key="TextControlBorderBrush" Color="#333333" />
                                                                        <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#444444" />
                                                                        <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#0078d4" />
                                                                        <SolidColorBrush x:Key="TextControlForeground" Color="#ffffff" />
                                                                    </TextBox.Resources>
                                                                </TextBox>
                                                                <Grid ColumnSpacing="4">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="*" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <Button Grid.Column="0" Content="Save" Click="SaveQuitHotKey_Click" HorizontalAlignment="Stretch" Height="24" Padding="0" FontSize="11" CornerRadius="4" />
                                                                    <Button Grid.Column="1" Content="Clear" Click="ClearQuitHotKey_Click" HorizontalAlignment="Stretch" Height="24" Padding="0" FontSize="11" CornerRadius="4" />
                                                                    <Button Grid.Column="2" Content="Cancel" Click="CancelQuitHotKey_Click" HorizontalAlignment="Stretch" Height="24" Padding="0" FontSize="11" CornerRadius="4" />
                                                                </Grid>
                                                            </StackPanel>
                                                        </Flyout>
                                                    </Button.Flyout>
                                                </Button>
                                            </Grid>

                                            <!-- メモの削除 -->
                                            <Grid x:Name="DeleteNoteItem" Padding="6,6" CornerRadius="4" Background="Transparent"
                                                  PointerEntered="SettingItem_PointerEntered" PointerExited="SettingItem_PointerExited"
                                                  PointerPressed="DeleteNoteItem_PointerPressed">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="&#xE74D;" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#FF453A" VerticalAlignment="Center" Margin="4,0,10,0" />
                                                <TextBlock Grid.Column="1" Text="Delete Note" FontSize="13" Foreground="#FF453A" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="2" Text="Ctrl+D" FontSize="12" Foreground="#FF453A" Opacity="0.7" VerticalAlignment="Center" Margin="0,0,4,0" />
                                            </Grid>
                                        </StackPanel>
                                    </Grid>
                                </ScrollViewer>
                            </Grid>
                        </Flyout>
                    </Button.Flyout>
                </Button>

                <!-- 両方表示ボタン -->
                <Button x:Name="ShowBothSidebarsButton" 
                        Content="&#xF57C;" 
                        Style="{StaticResource IconButtonStyle}" 
                        ToolTipService.ToolTip="両方表示" 
                        Click="ShowBothSidebarsButton_Click" />

                <!-- 両方非表示ボタン -->
                <Button x:Name="HideBothSidebarsButton" 
                        Content="&#xEDB4;" 
                        Style="{StaticResource IconButtonStyle}" 
                        ToolTipService.ToolTip="両方非表示" 
                        Click="HideBothSidebarsButton_Click" />

            </StackPanel>

            <!-- ドラッグ検出領域 -->
            <Grid Grid.Column="1" x:Name="TitleDragRegion" Background="Transparent">
                <!-- メモタイトル表示 -->
                <TextBlock x:Name="TitleTextBlock" Text="Untitled" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="12" Foreground="#ffffff" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" MaxLines="1" />
            </Grid>

            <!-- システムボタン（最小化・最大化・閉じる）用のスペースを確保 -->
            <Border Grid.Column="2" Width="140" Background="Transparent" />
        </Grid>

        <!-- 2. サイドバーおよびメインエリア (SplitViewによる統合) -->
        <SplitView x:Name="SidebarSplitView"
                   Grid.Row="1"
                   Grid.RowSpan="2"
                   DisplayMode="CompactOverlay"
                   CompactPaneLength="48"
                   OpenPaneLength="320"
                   IsPaneOpen="False"
                   PaneBackground="{StaticResource SidebarBackgroundBrush}"
                   PaneClosed="SidebarSplitView_PaneClosed"
                   PaneOpened="SidebarSplitView_PaneOpened">
            
            <SplitView.Pane>
                <!-- サイドバーペインのレイアウト -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="48" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- 左端のコンパクトアイコンバー (常に表示) -->
                    <Grid Grid.Column="0" Background="Transparent" BorderBrush="#2d2d2d" BorderThickness="0,0,1,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" /> <!-- Hamburger -->
                            <RowDefinition Height="*" />    <!-- Navigation Items -->
                        </Grid.RowDefinitions>

                        <Button x:Name="HamburgerButton"
                                Grid.Row="0"
                                Content="&#xE700;"
                                Style="{StaticResource IconButtonStyle}"
                                Width="36" Height="36"
                                HorizontalAlignment="Center"
                                Margin="0,8,0,0"
                                Click="HamburgerButton_Click"
                                ToolTipService.ToolTip="ナビゲーションの開閉" />

                        <StackPanel Grid.Row="1" Spacing="8" Margin="0,16,0,0">
                            <!-- メモ一覧 -->
                            <Grid x:Name="NotesMenuGrid">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="NotesActiveIndicator" Grid.Column="0" Width="3" Height="16" Background="#0078d4" CornerRadius="1.5" VerticalAlignment="Center" Visibility="Visible" />
                                <Button x:Name="NotesMenuButton"
                                        Grid.Column="1"
                                        Content="&#xEE40;"
                                        Style="{StaticResource IconButtonStyle}"
                                        Width="36" Height="36"
                                        HorizontalAlignment="Center"
                                        Click="NotesMenuButton_Click"
                                        ToolTipService.ToolTip="メモ一覧" />
                            </Grid>

                            <!-- 現在のタスク -->
                            <Grid x:Name="TasksMenuGrid">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="TasksActiveIndicator" Grid.Column="0" Width="3" Height="16" Background="#0078d4" CornerRadius="1.5" VerticalAlignment="Center" Visibility="Collapsed" />
                                <Button x:Name="TasksMenuButton"
                                        Grid.Column="1"
                                        Content="&#xE73E;"
                                        Style="{StaticResource IconButtonStyle}"
                                        Width="36" Height="36"
                                        HorizontalAlignment="Center"
                                        Click="TasksMenuButton_Click"
                                        ToolTipService.ToolTip="現在のタスク" />
                            </Grid>

                            <!-- すべてのタスク (横断ビュー) -->
                            <Grid x:Name="AllTasksMenuGrid">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="AllTasksActiveIndicator" Grid.Column="0" Width="3" Height="16" Background="#0078d4" CornerRadius="1.5" VerticalAlignment="Center" Visibility="Collapsed" />
                                <Button x:Name="AllTasksMenuButton"
                                        Grid.Column="1"
                                        Content="&#xE9D5;"
                                        Style="{StaticResource IconButtonStyle}"
                                        Width="36" Height="36"
                                        HorizontalAlignment="Center"
                                        Click="AllTasksMenuButton_Click"
                                        ToolTipService.ToolTip="すべてのタスク" />
                            </Grid>

                            <!-- すぐやる (Just Do It) -->
                            <Grid x:Name="JustDoItMenuGrid">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="JustDoItActiveIndicator" Grid.Column="0" Width="3" Height="16" Background="#0078d4" CornerRadius="1.5" VerticalAlignment="Center" Visibility="Collapsed" />
                                <Button x:Name="JustDoItMenuButton"
                                        Grid.Column="1"
                                        Content="&#xE945;"
                                        Style="{StaticResource IconButtonStyle}"
                                        Width="36" Height="36"
                                        HorizontalAlignment="Center"
                                        Click="JustDoItMenuButton_Click"
                                        ToolTipService.ToolTip="すぐやる (Just Do It)" />
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <!-- 右側の展開ペイン（開いているときのみ幅272） -->
                    <Grid Grid.Column="1" Background="Transparent" Margin="12,8,12,12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- 統合されたヘッダー (ビュータイトル & 固定ボタン) -->
                        <Grid Grid.Row="0" Margin="4,0,-8,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="PaneTitleTextBlock" Grid.Column="0" Text="Notes" FontSize="15" FontWeight="SemiBold" Foreground="#ffffff" VerticalAlignment="Center" />
                            <ToggleButton x:Name="DeleteModeButton" Grid.Column="1"
                                          Style="{StaticResource IconToggleButtonStyle}"
                                          Width="32" Height="32"
                                          Margin="0,0,4,0"
                                          Visibility="Collapsed"
                                          ToolTipService.ToolTip="削除モード">
                                <FontIcon Glyph="&#xE74D;" FontFamily="Segoe Fluent Icons" FontSize="12" Foreground="#ffffff" />
                            </ToggleButton>
                            <ToggleButton x:Name="PinSidebarButton" Grid.Column="2"
                                          Style="{StaticResource IconToggleButtonStyle}"
                                          Width="32" Height="32"
                                          Click="PinSidebarButton_Click"
                                          ToolTipService.ToolTip="サイドバーを固定">
                                <ToggleButton.Resources>
                                    <!-- Unchecked States -->
                                    <SolidColorBrush x:Key="ToggleButtonBackground" Color="Transparent" />
                                    <SolidColorBrush x:Key="ToggleButtonBackgroundPointerOver" Color="#22FFFFFF" />
                                    <SolidColorBrush x:Key="ToggleButtonBackgroundPressed" Color="#33FFFFFF" />
                                    <SolidColorBrush x:Key="ToggleButtonBorderBrush" Color="Transparent" />
                                    <SolidColorBrush x:Key="ToggleButtonBorderBrushPointerOver" Color="Transparent" />
                                    <SolidColorBrush x:Key="ToggleButtonBorderBrushPressed" Color="Transparent" />
                                    
                                    <!-- Checked States: Make background transparent/hover-only to avoid highlight -->
                                    <SolidColorBrush x:Key="ToggleButtonBackgroundChecked" Color="Transparent" />
                                    <SolidColorBrush x:Key="ToggleButtonBackgroundCheckedPointerOver" Color="#22FFFFFF" />
                                    <SolidColorBrush x:Key="ToggleButtonBackgroundCheckedPressed" Color="#33FFFFFF" />
                                    <SolidColorBrush x:Key="ToggleButtonBorderBrushChecked" Color="Transparent" />
                                    <SolidColorBrush x:Key="ToggleButtonBorderBrushCheckedPointerOver" Color="Transparent" />
                                    <SolidColorBrush x:Key="ToggleButtonBorderBrushCheckedPressed" Color="Transparent" />
                                    
                                    <!-- Foregrounds -->
                                    <SolidColorBrush x:Key="ToggleButtonForeground" Color="#ffffff" />
                                    <SolidColorBrush x:Key="ToggleButtonForegroundPointerOver" Color="#ffffff" />
                                    <SolidColorBrush x:Key="ToggleButtonForegroundPressed" Color="#ffffff" />
                                    <SolidColorBrush x:Key="ToggleButtonForegroundChecked" Color="#ffffff" />
                                    <SolidColorBrush x:Key="ToggleButtonForegroundCheckedPointerOver" Color="#ffffff" />
                                    <SolidColorBrush x:Key="ToggleButtonForegroundCheckedPressed" Color="#ffffff" />
                                </ToggleButton.Resources>
                                <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <!-- Base outline pin (always visible, draws the needle) -->
                                    <FontIcon Glyph="&#xE718;" 
                                              FontFamily="Segoe Fluent Icons" 
                                              FontSize="12"
                                              Foreground="#ffffff" />
                                    <!-- Filled pin overlay (only visible when pinned, fills the head) -->
                                    <FontIcon x:Name="SidebarPinFilledIcon" Glyph="&#xE841;" 
                                              FontFamily="Segoe Fluent Icons" 
                                              FontSize="12"
                                              Foreground="#ffffff"
                                              Visibility="Collapsed" />
                                </Grid>
                            </ToggleButton>
                        </Grid>


                        <!-- メモ一覧ビュー -->
                        <Grid x:Name="NotesViewContainer" Grid.Row="1" Visibility="Visible" RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            
                            <TextBox x:Name="SidebarNoteSearchBox" 
                                     Grid.Row="0"
                                     PlaceholderText="Search for notes..."
                                     HorizontalAlignment="Stretch"
                                     TextChanged="SidebarNoteSearchBox_TextChanged"
                                     KeyDown="SidebarNoteSearchBox_KeyDown">
                                <TextBox.Resources>
                                    <SolidColorBrush x:Key="TextControlBackground" Color="#252525" />
                                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#2d2d2d" />
                                    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#2d2d2d" />
                                    <SolidColorBrush x:Key="TextControlBorderBrush" Color="#333333" />
                                    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#444444" />
                                    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#0078d4" />
                                    <SolidColorBrush x:Key="TextControlForeground" Color="#ffffff" />
                                    <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="#ffffff" />
                                    <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#ffffff" />
                                    <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#777777" />
                                    <SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver" Color="#777777" />
                                    <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="#777777" />
                                </TextBox.Resources>
                            </TextBox>
                            
                            <ScrollViewer x:Name="SidebarNotesScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="SidebarNotesListContainer" Spacing="8">
                                    <!-- Recent セクション -->
                                    <StackPanel x:Name="SidebarRecentSection" Spacing="4">
                                        <TextBlock Text="Recent" FontSize="11" Foreground="#666666" FontWeight="SemiBold" Margin="4,4,0,2" />
                                        <ItemsControl x:Name="SidebarRecentListView" ItemTemplate="{StaticResource NoteItemTemplate}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Spacing="2" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                    </StackPanel>

                                    <!-- Pinned セクション -->
                                    <StackPanel x:Name="SidebarPinnedSection" Spacing="4">
                                        <TextBlock Text="Pinned" FontSize="11" Foreground="#666666" FontWeight="SemiBold" Margin="4,4,0,2" />
                                        <ItemsControl x:Name="SidebarPinnedListView" ItemTemplate="{StaticResource NoteItemTemplate}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Spacing="2" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                    </StackPanel>
                                    
                                    <!-- Notes セクション -->
                                    <StackPanel x:Name="SidebarNotesSection" Spacing="4">
                                        <TextBlock Text="Notes" FontSize="11" Foreground="#666666" FontWeight="SemiBold" Margin="4,4,0,2" />
                                        <ItemsControl x:Name="SidebarNotesListView" ItemTemplate="{StaticResource NoteItemTemplate}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Spacing="2" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>

                        <!-- 現在のタスクビュー -->
                        <Grid x:Name="TasksViewContainer" Grid.Row="1" Visibility="Collapsed" RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            
                            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="CurrentTasksListView">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Spacing="4" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="local:TaskItemViewModel">
                                            <Grid Padding="4" CornerRadius="4" Background="Transparent"
                                                  PointerEntered="TaskItemGrid_PointerEntered"
                                                  PointerExited="TaskItemGrid_PointerExited">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                
                                                <CheckBox Grid.Column="0" IsChecked="{x:Bind IsCompleted, Mode=TwoWay}" MinWidth="32" VerticalAlignment="Center" Margin="0,0,4,0" />
                                                
                                                <TextBox Grid.Column="1" Text="{x:Bind Title, Mode=TwoWay}"
                                                         FontSize="13" Foreground="#ffffff"
                                                         VerticalAlignment="Center"
                                                         BorderThickness="0" Background="Transparent"
                                                         Padding="0,4"
                                                         TextWrapping="Wrap">
                                                    <TextBox.Resources>
                                                        <SolidColorBrush x:Key="TextControlBackground" Color="Transparent" />
                                                        <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent" />
                                                        <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#252525" />
                                                        <SolidColorBrush x:Key="TextControlBorderBrush" Color="Transparent" />
                                                        <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent" />
                                                        <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#333333" />
                                                        <SolidColorBrush x:Key="TextControlForeground" Color="#ffffff" />
                                                        <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="#ffffff" />
                                                        <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#ffffff" />
                                                    </TextBox.Resources>
                                                </TextBox>
                                                
                                                <!-- すぐやるトグルボタン -->
                                                <Button x:Name="JustDoItTaskButton"
                                                        Grid.Column="2"
                                                        Style="{StaticResource IconButtonStyle}"
                                                        Width="28" Height="28"
                                                        Visibility="{x:Bind local:MainWindow.BoolToVisibility(IsJustDoIt), Mode=OneWay}"
                                                        Loaded="JustDoItTaskButton_Loaded"
                                                        Unloaded="JustDoItTaskButton_Unloaded"
                                                        ToolTipService.ToolTip="すぐやるに追加/解除">
                                                    <Path Data="M 9,0 L 2,10 L 7,10 L 5,18 L 13,8 L 8,8 Z"
                                                          Fill="{x:Bind local:MainWindow.GetJustDoItFillBrush(IsJustDoIt), Mode=OneWay}"
                                                          Stroke="{x:Bind local:MainWindow.GetJustDoItStrokeBrush(IsJustDoIt), Mode=OneWay}"
                                                          StrokeThickness="1.2"
                                                          Width="11" Height="11" Stretch="Uniform"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Button>
                                                
                                                <Button x:Name="DeleteTaskButton"
                                                        Grid.Column="3" Content="&#xE74D;"
                                                        Style="{StaticResource IconButtonStyle}"
                                                        Width="28" Height="28" FontSize="11"
                                                        Foreground="#FF453A"
                                                        Visibility="{Binding ElementName=DeleteModeButton, Path=IsChecked, Converter={StaticResource BoolToVisibilityConverter}}"
                                                        Loaded="DeleteTaskButton_Loaded"
                                                        Unloaded="DeleteTaskButton_Unloaded"
                                                        ToolTipService.ToolTip="タスクを削除" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <TextBox x:Name="AddTaskBox"
                                     Grid.Row="1"
                                     PlaceholderText="Add task..."
                                     BorderThickness="0,1,0,0"
                                     CornerRadius="0"
                                     Padding="4,8"
                                     KeyDown="AddTaskBox_KeyDown">
                                <TextBox.Resources>
                                    <SolidColorBrush x:Key="TextControlBackground" Color="Transparent" />
                                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent" />
                                    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent" />
                                    <SolidColorBrush x:Key="TextControlBorderBrush" Color="#2d2d2d" />
                                    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#2d2d2d" />
                                    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#2d2d2d" />
                                    <SolidColorBrush x:Key="TextControlForeground" Color="#ffffff" />
                                    <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#555555" />
                                </TextBox.Resources>
                            </TextBox>
                        </Grid>

                        <!-- すべてのタスクビュー (横断ビュー) -->
                        <Grid x:Name="AllTasksViewContainer" Grid.Row="1" Visibility="Collapsed" RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            
                            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="AllTasksGroupsControl">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Spacing="16" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
