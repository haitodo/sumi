<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="sumi.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:sumi"
    Title="sumi">

    <Window.SystemBackdrop>
        <DesktopAcrylicBackdrop />
    </Window.SystemBackdrop>

    <!-- 微細なデスクトップ壁紙透過を活かすため半透明の深炭色背景を設定 -->
    <Grid x:Name="RootGrid" Background="#ee141414">
        <Grid.Resources>
            <!-- ボタンのポインターホバー・プレス時の背景・フォアグラウンドカラーをオーバーライド -->
            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#2d2d2d" />
            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#3d3d3d" />
            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#ffffff" />
            <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#cccccc" />
            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent" />
            <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent" />
            <SolidColorBrush x:Key="ButtonBackgroundDisabled" Color="Transparent" />
            <SolidColorBrush x:Key="ButtonForegroundDisabled" Color="#444444" />

            <!-- トグルボタンの背景・フォアグラウンドカラーをオーバーライド -->
            <SolidColorBrush x:Key="ToggleButtonBackgroundChecked" Color="#444444" />
            <SolidColorBrush x:Key="ToggleButtonBackgroundCheckedPointerOver" Color="#555555" />
            <SolidColorBrush x:Key="ToggleButtonBackgroundCheckedPressed" Color="#666666" />
            <SolidColorBrush x:Key="ToggleButtonForegroundChecked" Color="#ffffff" />
            <SolidColorBrush x:Key="ToggleButtonForegroundCheckedPointerOver" Color="#ffffff" />
            <SolidColorBrush x:Key="ToggleButtonForegroundCheckedPressed" Color="#ffffff" />
            <SolidColorBrush x:Key="ToggleButtonBorderBrushChecked" Color="Transparent" />
            
            <SolidColorBrush x:Key="ToggleButtonBackgroundPointerOver" Color="#2d2d2d" />
            <SolidColorBrush x:Key="ToggleButtonBackgroundPressed" Color="#3d3d3d" />
            <SolidColorBrush x:Key="ToggleButtonForegroundPointerOver" Color="#ffffff" />
            <SolidColorBrush x:Key="ToggleButtonForegroundPressed" Color="#cccccc" />
            <SolidColorBrush x:Key="ToggleButtonBorderBrushPointerOver" Color="Transparent" />
            <SolidColorBrush x:Key="ToggleButtonBorderBrushPressed" Color="Transparent" />
            <SolidColorBrush x:Key="ToggleButtonBackgroundDisabled" Color="Transparent" />
            <SolidColorBrush x:Key="ToggleButtonForegroundDisabled" Color="#444444" />

            <!-- ヘッダーおよびステータスバーの共通ボタン用スタイル -->
            <Style x:Key="IconButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="CornerRadius" Value="4" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Width" Value="32" />
                <Setter Property="Height" Value="32" />
                <Setter Property="Foreground" Value="#cccccc" />
                <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
                <Setter Property="FontSize" Value="14" />
            </Style>

            <Style x:Key="IconToggleButtonStyle" TargetType="ToggleButton">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="CornerRadius" Value="4" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Width" Value="32" />
                <Setter Property="Height" Value="32" />
                <Setter Property="Foreground" Value="#cccccc" />
                <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
                <Setter Property="FontSize" Value="14" />
            </Style>

            <!-- メモアイテムの表示テンプレート -->
            <DataTemplate x:Key="NoteItemTemplate" x:DataType="local:NoteItemViewModel">
                <!-- 変更点: 直接のPointerイベント等を廃止し、Loaded/Unloadedで制御 -->
                <Grid Padding="4" Background="{x:Bind BackgroundBrush, Mode=OneTime}" CornerRadius="4" 
                      Loaded="NoteItemGrid_Loaded" Unloaded="NoteItemGrid_Unloaded">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- メモ選択領域 -->
                    <!-- 変更点: Clickイベントを直接繋がず、Loaded/Unloaded経由でハンドラを着脱 -->
                    <Button Grid.Column="0" 
                            HorizontalAlignment="Stretch" 
                            HorizontalContentAlignment="Stretch" 
                            Background="Transparent" 
                            BorderThickness="0"
                            Padding="8,6"
                            CornerRadius="4"
                            Loaded="NoteItemButton_Loaded"
                            Unloaded="NoteItemButton_Unloaded">
                        <Grid RowSpacing="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="{x:Bind Title}" FontSize="13" FontWeight="SemiBold" Foreground="#ffffff" TextTrimming="CharacterEllipsis" MaxLines="1" HorizontalAlignment="Stretch" />
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="4">
                                <Ellipse Width="6" Height="6" Fill="#4CAF50" VerticalAlignment="Center" Margin="0,1,0,0" Visibility="{x:Bind CurrentIndicatorVisibility}" />
                                <TextBlock Text="{x:Bind Subtitle}" FontSize="11" Foreground="#999999" VerticalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </Button>

                    <!-- アクション領域（ホバー時にのみ表示） -->
                    <StackPanel x:Name="ActionsPanel" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Spacing="2" Padding="0,0,4,0" Visibility="Collapsed">
                        <Button Style="{StaticResource IconButtonStyle}" 
                                Width="28" Height="28"
                                ToolTipService.ToolTip="{x:Bind PinToolTip}"
                                Loaded="PinItemButton_Loaded"
                                Unloaded="PinItemButton_Unloaded">
                            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                <!-- Base outline pin (always visible, draws the needle) -->
                                <FontIcon Glyph="&#xE718;" 
                                          FontFamily="Segoe Fluent Icons" 
                                          FontSize="12"
                                          Foreground="{x:Bind PinForeground}" />
                                <!-- Filled pin overlay (only visible when pinned, fills the head) -->
                                <FontIcon Glyph="&#xE841;" 
                                          FontFamily="Segoe Fluent Icons" 
                                          FontSize="12"
                                          Foreground="{x:Bind PinForeground}"
                                          Visibility="{x:Bind PinnedFillVisibility}" />
                            </Grid>
                        </Button>
                        <Button Content="&#xE74D;" 
                                Style="{StaticResource IconButtonStyle}" 
                                Width="28" Height="28" FontSize="11"
                                ToolTipService.ToolTip="削除"
                                Loaded="DeleteItemButton_Loaded"
                                Unloaded="DeleteItemButton_Unloaded" />
                    </StackPanel>
                </Grid>
            </DataTemplate>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- タイトルバー -->
            <RowDefinition Height="*" />    <!-- エディットエリア -->
            <RowDefinition Height="Auto" /> <!-- ステータスバー -->
        </Grid.RowDefinitions>

        <!-- 1. カスタムタイトルバー -->
        <Grid Grid.Row="0" Height="36" BorderBrush="#2d2d2d" BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" /> <!-- 左側操作ボタン群 -->
                <ColumnDefinition Width="*" />    <!-- 中央ドラッグ領域 (タイトル) -->
                <ColumnDefinition Width="Auto" /> <!-- 右側システムボタン用プレースホルダー -->
            </Grid.ColumnDefinitions>

            <!-- 操作ボタン群 (ドラッグ無効) -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0" Spacing="4">
                <!-- 設定ボタン -->
                <Button x:Name="PlayButton" Content="&#xE768;" Style="{StaticResource IconButtonStyle}" ToolTipService.ToolTip="設定">
                    <Button.Flyout>
                        <Flyout x:Name="SettingsFlyout" Placement="BottomEdgeAlignedLeft" Opened="SettingsFlyout_Opened">
                            <Flyout.FlyoutPresenterStyle>
                                <Style TargetType="FlyoutPresenter">
                                    <Setter Property="Background" Value="#ee1f1f1f" />
                                    <Setter Property="BorderBrush" Value="#333333" />
                                    <Setter Property="BorderThickness" Value="1" />
                                    <Setter Property="CornerRadius" Value="8" />
                                    <Setter Property="Padding" Value="12" />
                                    <Setter Property="MaxWidth" Value="340" />
                                    <Setter Property="MinWidth" Value="300" />
                                    <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled" />
                                    <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
                                </Style>
                            </Flyout.FlyoutPresenterStyle>
                            
                            <Grid RowSpacing="10" Width="300">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" /> <!-- 検索ボックス -->
                                    <RowDefinition Height="*" />    <!-- 設定項目リスト -->
                                </Grid.RowDefinitions>
                                
                                <TextBox x:Name="SettingsSearchBox" 
                                         Grid.Row="0"
                                         PlaceholderText="Search for actions..."
                                         TextChanged="SettingsSearchBox_TextChanged">
                                    <TextBox.Resources>
                                        <SolidColorBrush x:Key="TextControlBackground" Color="#252525" />
                                        <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#2d2d2d" />
                                        <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#2d2d2d" />
                                        <SolidColorBrush x:Key="TextControlBorderBrush" Color="#333333" />
                                        <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#444444" />
                                        <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#0078d4" />
                                        <SolidColorBrush x:Key="TextControlForeground" Color="#ffffff" />
                                        <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="#ffffff" />
                                        <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#ffffff" />
                                        <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#777777" />
                                        <SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver" Color="#777777" />
                                        <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="#777777" />
                                    </TextBox.Resources>
                                </TextBox>
                                
                                <ScrollViewer x:Name="SettingsScrollViewer" Grid.Row="1" MaxHeight="320" VerticalScrollBarVisibility="Auto">
                                    <StackPanel Spacing="4">
                                        <!-- Font -->
                                        <Grid x:Name="FontItem" Padding="6,6" CornerRadius="4" Background="Transparent"
                                              PointerEntered="SettingItem_PointerEntered" PointerExited="SettingItem_PointerExited">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="&#xE8D2;" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#cccccc" VerticalAlignment="Center" Margin="4,0,10,0" />
                                            <TextBlock Grid.Column="1" Text="Font" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center" />
                                            <ComboBox Grid.Column="2" x:Name="FontComboBox" FontSize="12" Height="28" Padding="8,0,24,0" SelectionChanged="FontComboBox_SelectionChanged" BorderThickness="1" BorderBrush="#333333" Background="#252525" CornerRadius="4">
                                                <x:String>Noto Sans JP</x:String>
                                                <x:String>Yu Gothic UI</x:String>
                                                <x:String>Segoe UI</x:String>
                                                <x:String>Consolas</x:String>
                                                <x:String>Georgia</x:String>
                                            </ComboBox>
                                        </Grid>

                                        <!-- Font Weight -->
                                        <Grid x:Name="FontWeightItem" Padding="6,6" CornerRadius="4" Background="Transparent"
                                              PointerEntered="SettingItem_PointerEntered" PointerExited="SettingItem_PointerExited">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="&#xE19B;" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#cccccc" VerticalAlignment="Center" Margin="4,0,10,0" />
                                            <TextBlock Grid.Column="1" Text="Font Weight" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center" />
                                            <ComboBox Grid.Column="2" x:Name="FontWeightComboBox" FontSize="12" Height="28" Padding="8,0,24,0" SelectionChanged="FontWeightComboBox_SelectionChanged" BorderThickness="1" BorderBrush="#333333" Background="#252525" CornerRadius="4">
                                                <x:String>Light</x:String>
                                                <x:String>Normal</x:String>
                                                <x:String>Medium</x:String>
                                                <x:String>SemiBold</x:String>
                                                <x:String>Bold</x:String>
                                            </ComboBox>
                                        </Grid>
                                        
                                        <!-- Font Size -->
                                        <Grid x:Name="FontSizeItem" Padding="6,6" CornerRadius="4" Background="Transparent"
                                              PointerEntered="SettingItem_PointerEntered" PointerExited="SettingItem_PointerExited">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="&#xE8E9;" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#cccccc" VerticalAlignment="Center" Margin="4,0,10,0" />
                                            <TextBlock Grid.Column="1" Text="Font Size" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                                <Button x:Name="FontSizeDecreaseButton" Content="&#xE108;" Style="{StaticResource IconButtonStyle}" Width="24" Height="24" FontSize="10" Click="FontSizeDecreaseButton_Click" VerticalAlignment="Center" />
                                                <Slider x:Name="FontSizeSlider" Minimum="10" Maximum="36" StepFrequency="0.5" Width="72" Margin="0,-6,0,-6" ValueChanged="FontSizeSlider_ValueChanged" />
                                                <Button x:Name="FontSizeIncreaseButton" Content="&#xE109;" Style="{StaticResource IconButtonStyle}" Width="24" Height="24" FontSize="10" Click="FontSizeIncreaseButton_Click" VerticalAlignment="Center" />
                                                <TextBlock x:Name="FontSizeValueText" Text="14.0" FontSize="12" Foreground="#999999" Width="28" TextAlignment="Right" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Grid>
                                        
                                        <!-- Line Spacing -->
                                        <Grid x:Name="LineSpacingItem" Padding="6,6" CornerRadius="4" Background="Transparent"
                                              PointerEntered="SettingItem_PointerEntered" PointerExited="SettingItem_PointerExited">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="&#xE8A7;" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#cccccc" VerticalAlignment="Center" Margin="4,0,10,0" />
                                            <TextBlock Grid.Column="1" Text="Line Spacing" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center" />
                                            <ComboBox Grid.Column="2" x:Name="LineSpacingComboBox" 
                                                      IsEditable="True" 
                                                      FontSize="12" Height="28" Padding="8,0,24,0" 
                                                      SelectionChanged="LineSpacingComboBox_SelectionChanged" 
                                                      LostFocus="LineSpacingComboBox_LostFocus"
                                                      BorderThickness="1" BorderBrush="#333333" Background="#252525" CornerRadius="4">
                                                <x:String>0.8</x:String>
                                                <x:String>0.85</x:String>
                                                <x:String>0.9</x:String>
                                                <x:String>0.95</x:String>
                                                <x:String>1.0</x:String>
                                            </ComboBox>
                                        </Grid>
                                        
                                        <!-- Paragraph Spacing -->
                                        <Grid x:Name="ParagraphSpacingItem" Padding="6,6" CornerRadius="4" Background="Transparent"
                                              PointerEntered="SettingItem_PointerEntered" PointerExited="SettingItem_PointerExited">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="&#xE8A5;" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#cccccc" VerticalAlignment="Center" Margin="4,0,10,0" />
                                            <TextBlock Grid.Column="1" Text="Paragraph Spacing" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center" />
                                            <ComboBox Grid.Column="2" x:Name="ParagraphSpacingComboBox" 
                                                      IsEditable="True" 
                                                      FontSize="12" Height="28" Padding="8,0,24,0" 
                                                      SelectionChanged="ParagraphSpacingComboBox_SelectionChanged" 
                                                      LostFocus="ParagraphSpacingComboBox_LostFocus"
                                                      BorderThickness="1" BorderBrush="#333333" Background="#252525" CornerRadius="4">
                                                <x:String>0</x:String>
                                                <x:String>2</x:String>
                                                <x:String>4</x:String>
                                                <x:String>6</x:String>
                                                <x:String>8</x:String>
                                                <x:String>10</x:String>
                                                <x:String>12</x:String>
                                            </ComboBox>
                                        </Grid>
                                        
                                        <!-- Opacity -->
                                        <Grid x:Name="OpacityItem" Padding="6,6" CornerRadius="4" Background="Transparent"
                                              PointerEntered="SettingItem_PointerEntered" PointerExited="SettingItem_PointerExited">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="&#xE7B3;" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#cccccc" VerticalAlignment="Center" Margin="4,0,10,0" />
                                            <TextBlock Grid.Column="1" Text="Opacity" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                                <Button x:Name="OpacityDecreaseButton" Content="&#xE108;" Style="{StaticResource IconButtonStyle}" Width="24" Height="24" FontSize="10" Click="OpacityDecreaseButton_Click" VerticalAlignment="Center" />
                                                <Slider x:Name="OpacitySlider" Minimum="0" Maximum="100" StepFrequency="1" Width="72" Margin="0,-6,0,-6" ValueChanged="OpacitySlider_ValueChanged" />
                                                <Button x:Name="OpacityIncreaseButton" Content="&#xE109;" Style="{StaticResource IconButtonStyle}" Width="24" Height="24" FontSize="10" Click="OpacityIncreaseButton_Click" VerticalAlignment="Center" />
                                                <TextBlock x:Name="OpacityValueText" Text="20%" FontSize="12" Foreground="#999999" Width="28" TextAlignment="Right" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Grid>
                                        
                                        <!-- Launch Hotkey -->
                                        <Grid x:Name="LaunchHotKeyItem" Padding="6,6" CornerRadius="4" Background="Transparent"
                                              PointerEntered="SettingItem_PointerEntered" PointerExited="SettingItem_PointerExited">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="&#xE765;" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#cccccc" VerticalAlignment="Center" Margin="4,0,10,0" />
                                            <TextBlock Grid.Column="1" Text="Launch Hotkey" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center" />
                                            <Button Grid.Column="2" x:Name="LaunchHotKeyButton" Width="100" Height="28" Padding="8,0" FontSize="12"
                                                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                    BorderThickness="1" BorderBrush="#333333" Background="#252525" Foreground="#ffffff" CornerRadius="4">
                                                <Button.Resources>
                                                    <SolidColorBrush x:Key="ButtonBackground" Color="#252525" />
                                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#2d2d2d" />
                                                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#3d3d3d" />
                                                    <SolidColorBrush x:Key="ButtonBorderBrush" Color="#333333" />
                                                    <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#444444" />
                                                    <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#0078d4" />
                                                    <SolidColorBrush x:Key="ButtonForeground" Color="#ffffff" />
                                                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#ffffff" />
                                                    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#ffffff" />
                                                </Button.Resources>
                                                <Button.Flyout>
                                                    <Flyout x:Name="LaunchHotKeyFlyout" Opened="HotKeyFlyout_Opened" Closed="HotKeyFlyout_Closed">
                                                        <Flyout.FlyoutPresenterStyle>
                                                            <Style TargetType="FlyoutPresenter">
                                                                <Setter Property="Background" Value="#ee1f1f1f" />
                                                                <Setter Property="BorderBrush" Value="#333333" />
                                                                <Setter Property="BorderThickness" Value="1" />
                                                                <Setter Property="CornerRadius" Value="8" />
                                                                <Setter Property="Padding" Value="10" />
                                                            </Style>
                                                        </Flyout.FlyoutPresenterStyle>
                                                        <StackPanel Spacing="8" Width="180">
                                                            <TextBlock Text="Press key combination:" FontSize="11" Foreground="#cccccc" />
                                                            <TextBox x:Name="LaunchHotKeyInput" Height="28" IsReadOnly="True" KeyDown="HotKeyInput_KeyDown" TextAlignment="Center" FontSize="12" VerticalContentAlignment="Center" Background="#252525" BorderThickness="1" BorderBrush="#333333" CornerRadius="4">
                                                                <TextBox.Resources>
                                                                    <SolidColorBrush x:Key="TextControlBackground" Color="#252525" />
                                                                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#2d2d2d" />
                                                                    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#2d2d2d" />
                                                                    <SolidColorBrush x:Key="TextControlBorderBrush" Color="#333333" />
                                                                    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#444444" />
                                                                    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#0078d4" />
                                                                    <SolidColorBrush x:Key="TextControlForeground" Color="#ffffff" />
                                                                </TextBox.Resources>
                                                            </TextBox>
                                                            <Grid ColumnSpacing="4">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>
                                                                <Button Grid.Column="0" Content="Save" Click="SaveLaunchHotKey_Click" HorizontalAlignment="Stretch" Height="24" Padding="0" FontSize="11" CornerRadius="4" />
                                                                <Button Grid.Column="1" Content="Clear" Click="ClearLaunchHotKey_Click" HorizontalAlignment="Stretch" Height="24" Padding="0" FontSize="11" CornerRadius="4" />
                                                                <Button Grid.Column="2" Content="Cancel" Click="CancelLaunchHotKey_Click" HorizontalAlignment="Stretch" Height="24" Padding="0" FontSize="11" CornerRadius="4" />
                                                            </Grid>
                                                        </StackPanel>
                                                    </Flyout>
                                                </Button.Flyout>
                                            </Button>
                                        </Grid>

                                        <!-- Quit Hotkey -->
                                        <Grid x:Name="QuitHotKeyItem" Padding="6,6" CornerRadius="4" Background="Transparent"
                                              PointerEntered="SettingItem_PointerEntered" PointerExited="SettingItem_PointerExited">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="&#xE106;" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#cccccc" VerticalAlignment="Center" Margin="4,0,10,0" />
                                            <TextBlock Grid.Column="1" Text="Quit Hotkey" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center" />
                                            <Button Grid.Column="2" x:Name="QuitHotKeyButton" Width="100" Height="28" Padding="8,0" FontSize="12"
                                                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                    BorderThickness="1" BorderBrush="#333333" Background="#252525" Foreground="#ffffff" CornerRadius="4">
                                                <Button.Resources>
                                                    <SolidColorBrush x:Key="ButtonBackground" Color="#252525" />
                                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#2d2d2d" />
                                                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#3d3d3d" />
                                                    <SolidColorBrush x:Key="ButtonBorderBrush" Color="#333333" />
                                                    <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#444444" />
                                                    <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#0078d4" />
                                                    <SolidColorBrush x:Key="ButtonForeground" Color="#ffffff" />
                                                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#ffffff" />
                                                    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#ffffff" />
                                                </Button.Resources>
                                                <Button.Flyout>
                                                    <Flyout x:Name="QuitHotKeyFlyout" Opened="HotKeyFlyout_Opened" Closed="HotKeyFlyout_Closed">
                                                        <Flyout.FlyoutPresenterStyle>
                                                            <Style TargetType="FlyoutPresenter">
                                                                <Setter Property="Background" Value="#ee1f1f1f" />
                                                                <Setter Property="BorderBrush" Value="#333333" />
                                                                <Setter Property="BorderThickness" Value="1" />
                                                                <Setter Property="CornerRadius" Value="8" />
                                                                <Setter Property="Padding" Value="10" />
                                                            </Style>
                                                        </Flyout.FlyoutPresenterStyle>
                                                        <StackPanel Spacing="8" Width="180">
                                                            <TextBlock Text="Press key combination:" FontSize="11" Foreground="#cccccc" />
                                                            <TextBox x:Name="QuitHotKeyInput" Height="28" IsReadOnly="True" KeyDown="HotKeyInput_KeyDown" TextAlignment="Center" FontSize="12" VerticalContentAlignment="Center" Background="#252525" BorderThickness="1" BorderBrush="#333333" CornerRadius="4">
                                                                <TextBox.Resources>
                                                                    <SolidColorBrush x:Key="TextControlBackground" Color="#252525" />
                                                                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#2d2d2d" />
                                                                    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#2d2d2d" />
                                                                    <SolidColorBrush x:Key="TextControlBorderBrush" Color="#333333" />
                                                                    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#444444" />
                                                                    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#0078d4" />
                                                                    <SolidColorBrush x:Key="TextControlForeground" Color="#ffffff" />
                                                                </TextBox.Resources>
                                                            </TextBox>
                                                            <Grid ColumnSpacing="4">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>
                                                                <Button Grid.Column="0" Content="Save" Click="SaveQuitHotKey_Click" HorizontalAlignment="Stretch" Height="24" Padding="0" FontSize="11" CornerRadius="4" />
                                                                <Button Grid.Column="1" Content="Clear" Click="ClearQuitHotKey_Click" HorizontalAlignment="Stretch" Height="24" Padding="0" FontSize="11" CornerRadius="4" />
                                                                <Button Grid.Column="2" Content="Cancel" Click="CancelQuitHotKey_Click" HorizontalAlignment="Stretch" Height="24" Padding="0" FontSize="11" CornerRadius="4" />
                                                            </Grid>
                                                        </StackPanel>
                                                    </Flyout>
                                                </Button.Flyout>
                                            </Button>
                                        </Grid>
                                        
                                        <!-- Delete Note -->
                                        <Grid x:Name="DeleteNoteItem" Padding="6,6" CornerRadius="4" Background="Transparent"
                                              PointerEntered="SettingItem_PointerEntered" PointerExited="SettingItem_PointerExited"
                                              PointerPressed="DeleteNoteItem_PointerPressed">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="&#xE74D;" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#FF453A" VerticalAlignment="Center" Margin="4,0,10,0" />
                                            <TextBlock Grid.Column="1" Text="Delete Note" FontSize="13" Foreground="#FF453A" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2" Text="Ctrl+D" FontSize="12" Foreground="#FF453A" Opacity="0.7" VerticalAlignment="Center" Margin="0,0,4,0" />
                                        </Grid>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Flyout>
                    </Button.Flyout>
                </Button>
                <!-- メモ一覧ボタン -->
                <Button x:Name="NotesButton" Content="&#xE8C8;" Style="{StaticResource IconButtonStyle}" ToolTipService.ToolTip="メモ一覧" Click="NotesButton_Click">
                    <Button.Flyout>
                        <Flyout x:Name="NotesFlyout" Placement="BottomEdgeAlignedLeft" Closed="NotesFlyout_Closed">
                            <Flyout.FlyoutPresenterStyle>
                                <Style TargetType="FlyoutPresenter">
                                    <Setter Property="Background" Value="#ee1f1f1f" />
                                    <Setter Property="BorderBrush" Value="#333333" />
                                    <Setter Property="BorderThickness" Value="1" />
                                    <Setter Property="CornerRadius" Value="8" />
                                    <Setter Property="Padding" Value="12" />
                                    <Setter Property="MaxWidth" Value="320" />
                                    <Setter Property="MinWidth" Value="280" />
                                    <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled" />
                                    <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
                                </Style>
                            </Flyout.FlyoutPresenterStyle>
                            
                            <Grid RowSpacing="8" Width="260">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" /> <!-- 検索ボックス -->
                                    <RowDefinition Height="*" />    <!-- メモ一覧スクロール領域 -->
                                </Grid.RowDefinitions>
                                
                                <!-- 検索ボックス -->
                                <TextBox x:Name="NoteSearchBox" 
                                         Grid.Row="0"
                                         PlaceholderText="Search for notes..."
                                         Width="260"
                                         HorizontalAlignment="Stretch"
                                         TextChanged="NoteSearchBox_TextChanged"
                                         KeyDown="NoteSearchBox_KeyDown">
                                    <TextBox.Resources>
                                        <!-- ダークテーマ用TextBoxスタイルオーバーライド -->
                                        <SolidColorBrush x:Key="TextControlBackground" Color="#252525" />
                                        <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#2d2d2d" />
                                        <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#2d2d2d" />
                                        <SolidColorBrush x:Key="TextControlBorderBrush" Color="#333333" />
                                        <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#444444" />
                                        <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#0078d4" />
                                        <SolidColorBrush x:Key="TextControlForeground" Color="#ffffff" />
                                        <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="#ffffff" />
                                        <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#ffffff" />
                                        <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#777777" />
                                        <SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver" Color="#777777" />
                                        <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="#777777" />
                                    </TextBox.Resources>
                                </TextBox>
                                
                                <!-- 一覧スクロール領域 -->
                                <ScrollViewer x:Name="NotesScrollViewer" Grid.Row="1" MaxHeight="300" VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="NotesListContainer" Spacing="8">
                                        <!-- Pinned セクション -->
                                        <StackPanel x:Name="PinnedSection" Spacing="4">
                                            <TextBlock Text="Pinned" FontSize="11" Foreground="#666666" FontWeight="SemiBold" Margin="4,4,0,2" />
                                            <ItemsControl x:Name="PinnedListView" ItemTemplate="{StaticResource NoteItemTemplate}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Spacing="2" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                            </ItemsControl>
                                        </StackPanel>
                                        
                                        <!-- Notes セクション -->
                                        <StackPanel x:Name="NotesSection" Spacing="4">
                                            <TextBlock Text="Notes" FontSize="11" Foreground="#666666" FontWeight="SemiBold" Margin="4,4,0,2" />
                                            <ItemsControl x:Name="NotesListView" ItemTemplate="{StaticResource NoteItemTemplate}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Spacing="2" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                            </ItemsControl>
                                        </StackPanel>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Flyout>
                    </Button.Flyout>
                </Button>
                <!-- 新規追加ボタン -->
                <Button x:Name="NewButton" Content="&#xE710;" Style="{StaticResource IconButtonStyle}" ToolTipService.ToolTip="新規作成" Click="NewButton_Click" />
            </StackPanel>

            <!-- ドラッグ検出領域 (タイトル表示) -->
            <Grid Grid.Column="1" x:Name="TitleDragRegion" Background="Transparent">
                <TextBlock x:Name="TitleTextBlock" Text="Untitled" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="8,0,8,0" FontSize="12.5" Foreground="#999999" FontWeight="Normal" TextTrimming="CharacterEllipsis" MaxLines="1" />
            </Grid>

            <!-- システムボタン（最小化・最大化・閉じる）用のスペースを確保 -->
            <Border Grid.Column="2" Width="140" Background="Transparent" />
        </Grid>

        <!-- 2. テキストエディットエリア -->
        <Grid Grid.Row="1">
            <RichEditBox 
                x:Name="MemoTextBox"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                BorderThickness="0"
                Padding="16,12,16,12"
                FontSize="14"
                FontFamily="Noto Sans JP, Yu Gothic UI"
                IsSpellCheckEnabled="False"
                IsTextPredictionEnabled="False"
                ScrollViewer.VerticalScrollBarVisibility="Auto"
                ScrollViewer.HorizontalScrollBarVisibility="Auto"
                TextChanged="MemoTextBox_TextChanged"
                SelectionChanged="MemoTextBox_SelectionChanged"
                PreviewKeyDown="MemoTextBox_PreviewKeyDown"
                SelectionFlyout="{x:Null}">
                
                <RichEditBox.Resources>
                    <!-- ホバーやフォーカスによる背景色変化と下部アクセント線を完全に無効化する軽量スタイル -->
                    <SolidColorBrush x:Key="TextControlBackground" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBorderBrush" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent" />
                    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent" />
                    <Thickness x:Key="TextControlBorderThemeThickness">0</Thickness>
                    <Thickness x:Key="TextControlBorderThemeThicknessFocused">0</Thickness>
                </RichEditBox.Resources>
            </RichEditBox>
            
            <!-- カスタムプレースホルダーテキスト -->
            <TextBlock
                x:Name="PlaceholderTextBlock"
                Text="Start writing..."
                Foreground="#555555"
                FontSize="14"
                FontFamily="Noto Sans JP, Yu Gothic UI"
                Padding="16,12,16,12"
                IsHitTestVisible="False"
                VerticalAlignment="Top"
                HorizontalAlignment="Left" />
        </Grid>

        <!-- 3. ステータスバー -->
        <Grid Grid.Row="2" Height="36" Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock 
                Grid.Column="0"
                x:Name="CharCountTextBlock"
                Text="0 characters"
                VerticalAlignment="Center"
                HorizontalAlignment="Left"
                Margin="16,0,0,0"
                FontSize="11.5"
                Foreground="#666666"
                TextTrimming="CharacterEllipsis" />

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0" Spacing="2">
                
                <ToggleButton x:Name="FormatBoldBtn" Content="&#xE19B;" Style="{StaticResource IconToggleButtonStyle}" AllowFocusOnInteraction="False" ToolTipService.ToolTip="太字 (Ctrl+B)" Click="FormatBold_Click" />
                <ToggleButton x:Name="FormatItalicBtn" Content="&#xE199;" Style="{StaticResource IconToggleButtonStyle}" AllowFocusOnInteraction="False" ToolTipService.ToolTip="斜体 (Ctrl+I)" Click="FormatItalic_Click" />
                <ToggleButton x:Name="FormatUnderlineBtn" Content="&#xE19A;" Style="{StaticResource IconToggleButtonStyle}" AllowFocusOnInteraction="False" ToolTipService.ToolTip="下線 (Ctrl+U)" Click="FormatUnderline_Click" />
                <ToggleButton x:Name="FormatStrikethroughBtn" Content="&#xEDE0;" Style="{StaticResource IconToggleButtonStyle}" AllowFocusOnInteraction="False" ToolTipService.ToolTip="取り消し線 (Ctrl+T)" Click="FormatStrikethrough_Click" />
                <ToggleButton x:Name="FormatHighlightBtn" Content="&#xE7E6;" Style="{StaticResource IconToggleButtonStyle}" AllowFocusOnInteraction="False" ToolTipService.ToolTip="ハイライト (Ctrl+H)" Click="FormatHighlight_Click" />
                
                <ToggleButton x:Name="FormatBulletListBtn" Content="&#xE8FD;" Style="{StaticResource IconToggleButtonStyle}" AllowFocusOnInteraction="False" ToolTipService.ToolTip="箇条書き (Ctrl+Shift+L)" Click="FormatBulletList_Click" />
                <ToggleButton x:Name="FormatNumberListBtn" Content="&#xE8EA;" Style="{StaticResource IconToggleButtonStyle}" AllowFocusOnInteraction="False" ToolTipService.ToolTip="番号付きリスト (Ctrl+Shift+N)" Click="FormatNumberList_Click" />

                <Border Width="1" Height="16" Background="#333333" Margin="4,0" />

                <ToggleButton x:Name="FormatHeading1Btn" Content="H1" Style="{StaticResource IconToggleButtonStyle}" FontFamily="Georgia" FontSize="13" FontWeight="Bold" AllowFocusOnInteraction="False" ToolTipService.ToolTip="見出し 1 (Ctrl+1)" Click="FormatHeading1_Click" />
                <ToggleButton x:Name="FormatHeading2Btn" Content="H2" Style="{StaticResource IconToggleButtonStyle}" FontFamily="Georgia" FontSize="12" FontWeight="Bold" AllowFocusOnInteraction="False" ToolTipService.ToolTip="見出し 2 (Ctrl+2)" Click="FormatHeading2_Click" />

                <Button Content="&#xE894;" Style="{StaticResource IconButtonStyle}" AllowFocusOnInteraction="False" ToolTipService.ToolTip="装飾をクリア (Ctrl+Space)" Click="FormatClear_Click" />
                
                <Border Width="1" Height="16" Background="#333333" Margin="4,0" />

                <Button x:Name="WordWrapButton" Content="T" Style="{StaticResource IconButtonStyle}" FontFamily="Georgia" FontSize="16" FontWeight="Normal" ToolTipService.ToolTip="右端折り返し切り替え" Click="WordWrapButton_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
