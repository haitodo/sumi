<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="sumi.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:sumi"
    Title="sumi">

    <Window.SystemBackdrop>
        <DesktopAcrylicBackdrop />
    </Window.SystemBackdrop>

    <!-- 微細なデスクトップ壁紙透過を活かすため半透明の深炭色背景を設定 -->
    <Grid x:Name="RootGrid" Background="#ee141414">
        <Grid.Resources>
            <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            
            <!-- テキスト入力コントロールのフォーカス枠線を上下左右均等（1px）に統一する設定 -->
            <Thickness x:Key="TextControlBorderThemeThickness">1</Thickness>
            <Thickness x:Key="TextControlBorderThemeThicknessFocused">1</Thickness>
            
            <AcrylicBrush x:Key="PanelAcrylicBrush"
                          TintColor="#1f1f1f"
                          TintOpacity="0.90"
                          FallbackColor="#1f1f1f" />
            
            <!-- ボタンのポインターホバー・プレス時の背景・フォアグラウンドカラーをオーバーライド -->
            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="White" Opacity="0.08" />
            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="White" Opacity="0.14" />
            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#ffffff" />
            <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#cccccc" />
            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent" />
            <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent" />

            <SolidColorBrush x:Key="ButtonBackgroundDisabled" Color="Transparent" />
            <SolidColorBrush x:Key="ButtonForegroundDisabled" Color="#444444" />

            <SolidColorBrush x:Key="ToggleButtonBackgroundChecked" Color="White" Opacity="0.15" />
            <SolidColorBrush x:Key="ToggleButtonBackgroundCheckedPointerOver" Color="White" Opacity="0.20" />
            <SolidColorBrush x:Key="ToggleButtonBackgroundCheckedPressed" Color="White" Opacity="0.25" />
            <SolidColorBrush x:Key="ToggleButtonForegroundChecked" Color="#ffffff" />

            <SolidColorBrush x:Key="ToggleButtonForegroundCheckedPointerOver" Color="#ffffff" />
            <SolidColorBrush x:Key="ToggleButtonForegroundCheckedPressed" Color="#ffffff" />
            <SolidColorBrush x:Key="ToggleButtonBorderBrushChecked" Color="Transparent" />

            <SolidColorBrush x:Key="ToggleButtonBackgroundPointerOver" Color="White" Opacity="0.08" />
            <SolidColorBrush x:Key="ToggleButtonBackgroundPressed" Color="White" Opacity="0.14" />
            <SolidColorBrush x:Key="ToggleButtonForegroundPointerOver" Color="#ffffff" />
            <SolidColorBrush x:Key="ToggleButtonForegroundPressed" Color="#cccccc" />
            <SolidColorBrush x:Key="ToggleButtonBorderBrushPointerOver" Color="Transparent" />
            <SolidColorBrush x:Key="ToggleButtonBorderBrushPressed" Color="Transparent" />
            <SolidColorBrush x:Key="ToggleButtonBackgroundDisabled" Color="Transparent" />
            <SolidColorBrush x:Key="ToggleButtonForegroundDisabled" Color="#444444" />

            <!-- ヘッダーおよびステータスバーの共通ボタン用スタイル -->
            <Style x:Key="IconButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="#002D2D2D" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="CornerRadius" Value="4" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Width" Value="32" />
                <Setter Property="Height" Value="32" />
                <Setter Property="Foreground" Value="#cccccc" />
                <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
                <Setter Property="FontSize" Value="14" />
            </Style>

            <Style x:Key="IconToggleButtonStyle" TargetType="ToggleButton">
                <Setter Property="Background" Value="#002D2D2D" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="CornerRadius" Value="4" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Width" Value="32" />
                <Setter Property="Height" Value="32" />
                <Setter Property="Foreground" Value="#cccccc" />
                <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
                <Setter Property="FontSize" Value="14" />
            </Style>


            <!-- メモアイテムの表示テンプレート -->
            <DataTemplate x:Key="NoteItemTemplate" x:DataType="local:NoteItemViewModel">
                <Grid Padding="0" Background="{x:Bind BackgroundBrush, Mode=OneTime}" CornerRadius="4" 
          PointerEntered="NoteItemGrid_PointerEntered" 
          PointerExited="NoteItemGrid_PointerExited">

                    <Border x:Name="HoverOverlay" Background="White" Opacity="0.08" CornerRadius="4" Visibility="Collapsed" IsHitTestVisible="False" />

                    <Button x:Name="NoteButton"
                HorizontalAlignment="Stretch" 
                HorizontalContentAlignment="Stretch" 
                Background="#002D2D2D" 
                BorderThickness="0"
                Padding="12,10,12,10"
                CornerRadius="4"
                Loaded="NoteItemButton_Loaded"
                Unloaded="NoteItemButton_Unloaded">

                        <Button.Resources>
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="Transparent" />
                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="White" Opacity="0.04" />
                        </Button.Resources>

                        <Grid RowSpacing="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="{x:Bind Title}" FontSize="13" FontWeight="SemiBold" Foreground="#ffffff" TextTrimming="CharacterEllipsis" MaxLines="1" HorizontalAlignment="Stretch" />
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="4">
                                <Ellipse Width="6" Height="6" Fill="#4CAF50" VerticalAlignment="Center" Margin="0,1,0,0" Visibility="{x:Bind CurrentIndicatorVisibility}" />
                                <TextBlock Text="{x:Bind Subtitle}" FontSize="11" Foreground="#999999" VerticalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </Button>

                    <StackPanel x:Name="ActionsPanel" 
                    HorizontalAlignment="Right" 
                    Orientation="Horizontal" 
                    VerticalAlignment="Center" 
                    Spacing="2" 
                    Padding="8,0,8,0" 
                    Visibility="Collapsed">
                        <Button Style="{StaticResource IconButtonStyle}" 
                                Width="28" Height="28"
                                ToolTipService.ToolTip="{x:Bind PinToolTip}"
                                Loaded="PinItemButton_Loaded"
                                Unloaded="PinItemButton_Unloaded">
                            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                <!-- Base outline pin (always visible, draws the needle) -->
                                <FontIcon Glyph="&#xE718;" 
                                          FontFamily="Segoe Fluent Icons" 
                                          FontSize="12"
                                          Foreground="{x:Bind PinForeground}" />
                                <!-- Filled pin overlay (only visible when pinned, fills the head) -->
                                <FontIcon Glyph="&#xE841;" 
                                          FontFamily="Segoe Fluent Icons" 
                                          FontSize="12"
                                          Foreground="{x:Bind PinForeground}"
                                          Visibility="{x:Bind PinnedFillVisibility}" />
                            </Grid>
                        </Button>
                        <Button Content="&#xE74D;" 
                                Style="{StaticResource IconButtonStyle}" 
                                Width="28" Height="28" FontSize="11"
                                ToolTipService.ToolTip="削除"
                                Visibility="{x:Bind DeleteButtonVisibility}"
                                Loaded="DeleteItemButton_Loaded"
                                Unloaded="DeleteItemButton_Unloaded" />
                    </StackPanel>
                </Grid>
            </DataTemplate>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- タイトルバー -->
            <RowDefinition Height="*" />    <!-- エディットエリア -->
            <RowDefinition Height="Auto" /> <!-- ステータスバー -->
        </Grid.RowDefinitions>

        <!-- 1. カスタムタイトルバー -->
        <Grid Grid.Row="0" Height="36" BorderBrush="#2d2d2d" BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" /> <!-- 左側操作ボタン群 -->
                <ColumnDefinition Width="*" />    <!-- 中央ドラッグ領域 (タイトル) -->
                <ColumnDefinition Width="Auto" /> <!-- 右側システムボタン用プレースホルダー -->
            </Grid.ColumnDefinitions>

            <!-- 操作ボタン群 (ドラッグ無効) -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0" Spacing="4">
                <!-- 設定ボタン -->
                <Button x:Name="PlayButton" Content="&#xE713;" Style="{StaticResource IconButtonStyle}" ToolTipService.ToolTip="設定" Click="PlayButton_Click" />

                <!-- 左右サイドバーの表示・非表示切り替えボタン -->
                <Button x:Name="ToggleSidebarsButton" 
                        Content="&#xF57C;" 
                        Style="{StaticResource IconButtonStyle}" 
                        ToolTipService.ToolTip="両方表示" 
                        Click="ToggleSidebarsButton_Click" />

            </StackPanel>

            <!-- ドラッグ検出領域 -->
            <Grid Grid.Column="1" x:Name="TitleDragRegion" Background="Transparent">
                <!-- メモタイトル表示 -->
                <TextBlock x:Name="TitleTextBlock" Text="Untitled" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="12" Foreground="#ffffff" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" MaxLines="1" />
            </Grid>

            <!-- システムボタン（最小化・最大化・閉じる）用のスペースを確保 -->
            <Border Grid.Column="2" Width="140" Background="Transparent" />
        </Grid>

        <!-- 2. サイドバーおよびメインエリア (SplitViewによる統合) -->
        <SplitView x:Name="SidebarSplitView"
                   Grid.Row="1"
                   Grid.RowSpan="2"
                   DisplayMode="CompactOverlay"
                   CompactPaneLength="48"
                   OpenPaneLength="320"
                   IsPaneOpen="False"
                   PaneBackground="{StaticResource SidebarBackgroundBrush}"
                   PaneClosed="SidebarSplitView_PaneClosed"
                   PaneOpened="SidebarSplitView_PaneOpened"
                   PaneOpening="SidebarSplitView_PaneOpening"
                   PaneClosing="SidebarSplitView_PaneClosing">
            
            <SplitView.Pane>
                <!-- サイドバーペインのレイアウト -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="48" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- 左端のコンパクトアイコンバー (常に表示) -->
                    <Grid Grid.Column="0" Background="Transparent" BorderBrush="#2d2d2d" BorderThickness="0,0,1,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" /> <!-- Hamburger -->
                            <RowDefinition Height="*" />    <!-- Navigation Items -->
                        </Grid.RowDefinitions>

                        <Button x:Name="HamburgerButton"
                                Grid.Row="0"
                                Content="&#xE700;"
                                Style="{StaticResource IconButtonStyle}"
                                Width="36" Height="36"
                                HorizontalAlignment="Center"
                                Margin="0,8,0,0"
                                Click="HamburgerButton_Click"
                                ToolTipService.ToolTip="ナビゲーションの開閉" />

                        <StackPanel Grid.Row="1" Spacing="8" Margin="0,16,0,0">
                            <!-- メモ一覧 -->
                            <Grid x:Name="NotesMenuGrid">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="NotesActiveIndicator" Grid.Column="0" Width="3" Height="16" Background="#0078d4" CornerRadius="1.5" VerticalAlignment="Center" Visibility="Visible" />
                                <Button x:Name="NotesMenuButton"
                                        Grid.Column="1"
                                        Content="&#xEE40;"
                                        Style="{StaticResource IconButtonStyle}"
                                        Width="36" Height="36"
                                        HorizontalAlignment="Center"
                                        Click="NotesMenuButton_Click"
                                        ToolTipService.ToolTip="メモ一覧" />
                            </Grid>

                            <!-- 現在のタスク -->
                            <Grid x:Name="TasksMenuGrid">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="TasksActiveIndicator" Grid.Column="0" Width="3" Height="16" Background="#0078d4" CornerRadius="1.5" VerticalAlignment="Center" Visibility="Collapsed" />
                                <Button x:Name="TasksMenuButton"
                                        Grid.Column="1"
                                        Content="&#xE73E;"
                                        Style="{StaticResource IconButtonStyle}"
                                        Width="36" Height="36"
                                        HorizontalAlignment="Center"
                                        Click="TasksMenuButton_Click"
                                        ToolTipService.ToolTip="現在のタスク" />
                            </Grid>

                            <!-- すべてのタスク (横断ビュー) -->
                            <Grid x:Name="AllTasksMenuGrid">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="AllTasksActiveIndicator" Grid.Column="0" Width="3" Height="16" Background="#0078d4" CornerRadius="1.5" VerticalAlignment="Center" Visibility="Collapsed" />
                                <Button x:Name="AllTasksMenuButton"
                                        Grid.Column="1"
                                        Content="&#xE9D5;"
                                        Style="{StaticResource IconButtonStyle}"
                                        Width="36" Height="36"
                                        HorizontalAlignment="Center"
                                        Click="AllTasksMenuButton_Click"
                                        ToolTipService.ToolTip="すべてのタスク" />
                            </Grid>

                            <!-- すぐやる (Just Do It) -->
                            <Grid x:Name="JustDoItMenuGrid">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="JustDoItActiveIndicator" Grid.Column="0" Width="3" Height="16" Background="#0078d4" CornerRadius="1.5" VerticalAlignment="Center" Visibility="Collapsed" />
                                <Button x:Name="JustDoItMenuButton"
                                        Grid.Column="1"
                                        Content="&#xE945;"
                                        Style="{StaticResource IconButtonStyle}"
                                        Width="36" Height="36"
                                        HorizontalAlignment="Center"
                                        Click="JustDoItMenuButton_Click"
                                        ToolTipService.ToolTip="すぐやる (Just Do It)" />
                            </Grid>

                            <!-- タグ (Tags) -->
                            <Grid x:Name="TagsMenuGrid">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="TagsActiveIndicator" Grid.Column="0" Width="3" Height="16" Background="#0078d4" CornerRadius="1.5" VerticalAlignment="Center" Visibility="Collapsed" />
                                <Button x:Name="TagsMenuButton"
                                        Grid.Column="1"
                                        Content="&#xE8EC;"
                                        Style="{StaticResource IconButtonStyle}"
                                        Width="36" Height="36"
                                        HorizontalAlignment="Center"
                                        Click="TagsMenuButton_Click"
                                        ToolTipService.ToolTip="タグ" />
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <!-- 右側の展開ペイン（開いているときのみ幅272） -->
                    <Grid Grid.Column="1" Background="Transparent" Margin="12,8,12,12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- 統合されたヘッダー (ビュータイトル & 固定ボタン) -->
                        <Grid Grid.Row="0" Margin="4,0,-8,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="PaneTitleTextBlock" Grid.Column="0" Text="Notes" FontSize="15" FontWeight="SemiBold" Foreground="#ffffff" VerticalAlignment="Center" />
                            <ToggleButton x:Name="DeleteModeButton" Grid.Column="1"
                                          Style="{StaticResource IconToggleButtonStyle}"
                                          Width="32" Height="32"
                                          Margin="0,0,4,0"
                                          Visibility="Collapsed"
                                          ToolTipService.ToolTip="削除モード">
                                <FontIcon Glyph="&#xE74D;" FontFamily="Segoe Fluent Icons" FontSize="12" Foreground="#ffffff" />
                            </ToggleButton>
                            <ToggleButton x:Name="PinSidebarButton" Grid.Column="2"
                                          Style="{StaticResource IconToggleButtonStyle}"
                                          Width="32" Height="32"
                                          Click="PinSidebarButton_Click"
                                          ToolTipService.ToolTip="サイドバーを固定">
                                <ToggleButton.Resources>
                                    <!-- Unchecked States -->
                                    <SolidColorBrush x:Key="ToggleButtonBackground" Color="Transparent" />
                                    <SolidColorBrush x:Key="ToggleButtonBackgroundPointerOver" Color="#22FFFFFF" />
                                    <SolidColorBrush x:Key="ToggleButtonBackgroundPressed" Color="#33FFFFFF" />
                                    <SolidColorBrush x:Key="ToggleButtonBorderBrush" Color="Transparent" />
                                    <SolidColorBrush x:Key="ToggleButtonBorderBrushPointerOver" Color="Transparent" />
                                    <SolidColorBrush x:Key="ToggleButtonBorderBrushPressed" Color="Transparent" />
                                    
                                    <!-- Checked States: Make background transparent/hover-only to avoid highlight -->
                                    <SolidColorBrush x:Key="ToggleButtonBackgroundChecked" Color="Transparent" />
                                    <SolidColorBrush x:Key="ToggleButtonBackgroundCheckedPointerOver" Color="#22FFFFFF" />
                                    <SolidColorBrush x:Key="ToggleButtonBackgroundCheckedPressed" Color="#33FFFFFF" />
                                    <SolidColorBrush x:Key="ToggleButtonBorderBrushChecked" Color="Transparent" />
                                    <SolidColorBrush x:Key="ToggleButtonBorderBrushCheckedPointerOver" Color="Transparent" />
                                    <SolidColorBrush x:Key="ToggleButtonBorderBrushCheckedPressed" Color="Transparent" />
                                    
                                    <!-- Foregrounds -->
                                    <SolidColorBrush x:Key="ToggleButtonForeground" Color="#ffffff" />
                                    <SolidColorBrush x:Key="ToggleButtonForegroundPointerOver" Color="#ffffff" />
                                    <SolidColorBrush x:Key="ToggleButtonForegroundPressed" Color="#ffffff" />
                                    <SolidColorBrush x:Key="ToggleButtonForegroundChecked" Color="#ffffff" />
                                    <SolidColorBrush x:Key="ToggleButtonForegroundCheckedPointerOver" Color="#ffffff" />
                                    <SolidColorBrush x:Key="ToggleButtonForegroundCheckedPressed" Color="#ffffff" />
                                </ToggleButton.Resources>
                                <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <!-- Base outline pin (always visible, draws the needle) -->
                                    <FontIcon Glyph="&#xE718;" 
                                              FontFamily="Segoe Fluent Icons" 
                                              FontSize="12"
                                              Foreground="#ffffff" />
                                    <!-- Filled pin overlay (only visible when pinned, fills the head) -->
                                    <FontIcon x:Name="SidebarPinFilledIcon" Glyph="&#xE841;" 
                                              FontFamily="Segoe Fluent Icons" 
                                              FontSize="12"
                                              Foreground="#ffffff"
                                              Visibility="Collapsed" />
                                </Grid>
                            </ToggleButton>
                        </Grid>


                        <!-- メモ一覧ビュー -->
                        <Grid x:Name="NotesViewContainer" Grid.Row="1" Visibility="Visible" RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            
                            <TextBox x:Name="SidebarNoteSearchBox" 
                                     Grid.Row="0"
                                     PlaceholderText="Search for notes..."
                                     HorizontalAlignment="Stretch"
                                     TextChanged="SidebarNoteSearchBox_TextChanged"
                                     KeyDown="SidebarNoteSearchBox_KeyDown">
                                <TextBox.Resources>
                                    <SolidColorBrush x:Key="TextControlBackground" Color="White" Opacity="0.06" />
                                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="White" Opacity="0.10" />
                                    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="White" Opacity="0.14" />
                                    <SolidColorBrush x:Key="TextControlBorderBrush" Color="White" Opacity="0.10" />
                                    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="White" Opacity="0.15" />
                                    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="White" Opacity="0.30" />
                                    <SolidColorBrush x:Key="TextControlForeground" Color="#ffffff" />
                                    <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="#ffffff" />
                                    <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#ffffff" />
                                    <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#777777" />
                                    <SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver" Color="#777777" />
                                    <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="#777777" />
                                </TextBox.Resources>
                            </TextBox>

                            <Grid Grid.Row="1" x:Name="SidebarActiveTagFilterGrid" Visibility="Collapsed" Margin="0,4,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Background="#1f1f1f" CornerRadius="10" Padding="8,4" BorderBrush="#333333" BorderThickness="1" HorizontalAlignment="Left">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <FontIcon Glyph="&#xE8EC;" FontSize="11" Foreground="#0078d4" VerticalAlignment="Center" />
                                        <TextBlock x:Name="SidebarActiveTagFilterTextBlock" FontSize="11" Foreground="#ffffff" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <Button Grid.Column="1" Content="&#xE10A;" Style="{StaticResource IconButtonStyle}" Width="24" Height="24" FontSize="10" Click="ClearSidebarActiveTagFilter_Click" ToolTipService.ToolTip="フィルターを解除" />
                            </Grid>
                            
                            <ScrollViewer x:Name="SidebarNotesScrollViewer" Grid.Row="2" VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="SidebarNotesListContainer" Spacing="8">
                                    <!-- Recent セクション -->
                                    <StackPanel x:Name="SidebarRecentSection" Spacing="4">
                                        <TextBlock Text="Recent" FontSize="11" Foreground="#666666" FontWeight="SemiBold" Margin="4,4,0,2" />
                                        <ItemsControl x:Name="SidebarRecentListView" ItemTemplate="{StaticResource NoteItemTemplate}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Spacing="2" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                    </StackPanel>

                                    <!-- Pinned セクション -->
                                    <StackPanel x:Name="SidebarPinnedSection" Spacing="4">
                                        <TextBlock Text="Pinned" FontSize="11" Foreground="#666666" FontWeight="SemiBold" Margin="4,4,0,2" />
                                        <ItemsControl x:Name="SidebarPinnedListView" ItemTemplate="{StaticResource NoteItemTemplate}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Spacing="2" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                    </StackPanel>
                                    
                                    <!-- Notes セクション -->
                                    <StackPanel x:Name="SidebarNotesSection" Spacing="4">
                                        <TextBlock Text="Notes" FontSize="11" Foreground="#666666" FontWeight="SemiBold" Margin="4,4,0,2" />
                                        <ItemsControl x:Name="SidebarNotesListView" ItemTemplate="{StaticResource NoteItemTemplate}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Spacing="2" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>

                        <!-- 現在のタスクビュー -->
                        <Grid x:Name="TasksViewContainer" Grid.Row="1" Visibility="Collapsed" RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            
                            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="CurrentTasksListView">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Spacing="2" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="local:TaskItemViewModel">
                                            <Grid Padding="4,2" CornerRadius="4" Background="Transparent"
                                                  PointerEntered="TaskItemGrid_PointerEntered"
                                                  PointerExited="TaskItemGrid_PointerExited">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                
                                                <CheckBox Grid.Column="0" IsChecked="{x:Bind IsCompleted, Mode=TwoWay}" MinWidth="32" VerticalAlignment="Center" Margin="0,0,4,0" />
                                                
                                                <Grid Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock x:Name="CurrentTaskTitleTextBlock"
                                                               Text="{x:Bind Title, Mode=OneWay}"
                                                               FontSize="13" Foreground="#ffffff"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"
                                                               TextWrapping="NoWrap"
                                                               Tapped="CurrentTaskTitleTextBlock_Tapped"
                                                               ToolTipService.ToolTip="{x:Bind Title, Mode=OneWay}" />
                                                    <TextBox x:Name="CurrentTaskTitleTextBox"
                                                             Text="{x:Bind Title, Mode=TwoWay}"
                                                             FontSize="13" Foreground="#ffffff"
                                                             VerticalAlignment="Center"
                                                             BorderThickness="0" Background="Transparent"
                                                             Padding="0,4"
                                                             TextWrapping="NoWrap"
                                                             Visibility="Collapsed"
                                                             LostFocus="CurrentTaskTitleTextBox_LostFocus"
                                                             KeyDown="CurrentTaskTitleTextBox_KeyDown">
                                                        <TextBox.Resources>
                                                            <SolidColorBrush x:Key="TextControlBackground" Color="Transparent" />
                                                            <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent" />
                                                            <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#252525" />
                                                            <SolidColorBrush x:Key="TextControlBorderBrush" Color="Transparent" />
                                                            <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent" />
                                                            <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#333333" />
                                                            <SolidColorBrush x:Key="TextControlForeground" Color="#ffffff" />
                                                            <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="#ffffff" />
                                                            <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#ffffff" />
                                                        </TextBox.Resources>
                                                    </TextBox>
                                                </Grid>
                                                
                                                <!-- すぐやるトグルボタン -->
                                                <Button x:Name="JustDoItTaskButton"
                                                        Grid.Column="2"
                                                        Style="{StaticResource IconButtonStyle}"
                                                        Width="28" Height="28"
                                                        Visibility="{x:Bind local:MainWindow.BoolToVisibility(IsJustDoIt), Mode=OneWay}"
                                                        Loaded="JustDoItTaskButton_Loaded"
                                                        Unloaded="JustDoItTaskButton_Unloaded"
                                                        ToolTipService.ToolTip="すぐやるに追加/解除">
                                                    <Path Data="M 9,0 L 2,10 L 7,10 L 5,18 L 13,8 L 8,8 Z"
                                                          Fill="{x:Bind local:MainWindow.GetJustDoItFillBrush(IsJustDoIt), Mode=OneWay}"
                                                          Stroke="{x:Bind local:MainWindow.GetJustDoItStrokeBrush(IsJustDoIt), Mode=OneWay}"
                                                          StrokeThickness="1.2"
                                                          Width="11" Height="11" Stretch="Uniform"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Button>
                                                
                                                <Button x:Name="DeleteTaskButton"
                                                        Grid.Column="3" Content="&#xE74D;"
                                                        Style="{StaticResource IconButtonStyle}"
                                                        Width="28" Height="28" FontSize="11"
                                                        Foreground="#FF453A"
                                                        Visibility="{Binding ElementName=DeleteModeButton, Path=IsChecked, Converter={StaticResource BoolToVisibilityConverter}}"
                                                        Loaded="DeleteTaskButton_Loaded"
                                                        Unloaded="DeleteTaskButton_Unloaded"
                                                        ToolTipService.ToolTip="タスクを削除" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <TextBox x:Name="AddTaskBox"
                                     Grid.Row="1"
                                     PlaceholderText="Add task..."
                                     BorderThickness="0,1,0,0"
                                     CornerRadius="0"
                                     Padding="4,8"
                                     KeyDown="AddTaskBox_KeyDown">
                                <TextBox.Resources>
                                    <SolidColorBrush x:Key="TextControlBackground" Color="Transparent" />
                                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent" />
                                    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent" />
                                    <SolidColorBrush x:Key="TextControlBorderBrush" Color="#2d2d2d" />
                                    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#2d2d2d" />
                                    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#2d2d2d" />
                                    <SolidColorBrush x:Key="TextControlForeground" Color="#ffffff" />
                                    <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#555555" />
                                </TextBox.Resources>
                            </TextBox>
                        </Grid>

                        <!-- すべてのタスクビュー (横断ビュー) -->
                        <Grid x:Name="AllTasksViewContainer" Grid.Row="1" Visibility="Collapsed" RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            
                            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="AllTasksGroupsControl">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Spacing="16" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="local:AllTasksGroupViewModel">
                                            <StackPanel Spacing="4">
                                                <Button Content="{x:Bind NoteTitle}"
                                                        Background="#002D2D2D"
                                                        BorderThickness="0"
                                                        Foreground="#0078d4"
                                                        FontWeight="SemiBold"
                                                        FontSize="12"
                                                        Padding="4,2"
                                                        HorizontalAlignment="Left"
                                                        Click="AllTasksGroupHeader_Click"
                                                        DataContext="{x:Bind}" />
                                                
                                                <ItemsControl ItemsSource="{x:Bind Tasks}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Spacing="2" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="local:TaskItemViewModel">
                                                            <Grid Padding="4,2" Background="Transparent"
                                                                  PointerPressed="AllTaskItem_PointerPressed"
                                                                  PointerEntered="AllTaskItemGrid_PointerEntered"
                                                                  PointerExited="AllTaskItemGrid_PointerExited">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <CheckBox Grid.Column="0" IsChecked="{x:Bind IsCompleted, Mode=TwoWay}" MinWidth="32" VerticalAlignment="Center" Margin="0,0,4,0" />
                                                                <TextBlock Grid.Column="1" Text="{x:Bind Title}" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{x:Bind Title, Mode=OneWay}" />
                                                                
                                                                <Button x:Name="AllJustDoItButton"
                                                                        Grid.Column="2"
                                                                        Style="{StaticResource IconButtonStyle}"
                                                                        Width="28" Height="28"
                                                                        Visibility="{x:Bind local:MainWindow.BoolToVisibility(IsJustDoIt), Mode=OneWay}"
                                                                        Loaded="AllJustDoItButton_Loaded"
                                                                        Unloaded="AllJustDoItButton_Unloaded"
                                                                        ToolTipService.ToolTip="すぐやるに追加/解除">
                                                                    <Path Data="M 9,0 L 2,10 L 7,10 L 5,18 L 13,8 L 8,8 Z"
                                                                          Fill="{x:Bind local:MainWindow.GetJustDoItFillBrush(IsJustDoIt), Mode=OneWay}"
                                                                          Stroke="{x:Bind local:MainWindow.GetJustDoItStrokeBrush(IsJustDoIt), Mode=OneWay}"
                                                                          StrokeThickness="1.2"
                                                                          Width="11" Height="11" Stretch="Uniform"
                                                                          HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                </Button>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>

                        <!-- すぐやるビュー (Just Do It - 左) -->
                        <Grid x:Name="JustDoItViewContainer" Grid.Row="1" Visibility="Collapsed" RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            
                            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="LeftJustDoItTasksGroupsControl">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Spacing="16" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="local:AllTasksGroupViewModel">
                                            <StackPanel Spacing="4">
                                                <Button Content="{x:Bind NoteTitle}"
                                                        Background="#002D2D2D"
                                                        BorderThickness="0"
                                                        Foreground="#0078d4"
                                                        FontWeight="SemiBold"
                                                        FontSize="12"
                                                        Padding="4,2"
                                                        HorizontalAlignment="Left"
                                                        Click="AllTasksGroupHeader_Click"
                                                        DataContext="{x:Bind}" />
                                                
                                                <ItemsControl ItemsSource="{x:Bind Tasks}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Spacing="2" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="local:TaskItemViewModel">
                                                            <Grid Padding="4,2" Background="Transparent"
                                                                  PointerPressed="AllTaskItem_PointerPressed"
                                                                  PointerEntered="JustDoItTaskItemGrid_PointerEntered"
                                                                  PointerExited="JustDoItTaskItemGrid_PointerExited">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <CheckBox Grid.Column="0" IsChecked="{x:Bind IsCompleted, Mode=TwoWay}" MinWidth="32" VerticalAlignment="Center" Margin="0,0,4,0" />
                                                                <TextBlock Grid.Column="1" Text="{x:Bind Title}" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{x:Bind Title, Mode=OneWay}" />
                                                                
                                                                <Button x:Name="JustDoItToggleBtn"
                                                                        Grid.Column="2"
                                                                        Style="{StaticResource IconButtonStyle}"
                                                                        Width="28" Height="28"
                                                                        Visibility="Collapsed"
                                                                        Loaded="JustDoItToggleBtn_Loaded"
                                                                        Unloaded="JustDoItToggleBtn_Unloaded"
                                                                        ToolTipService.ToolTip="すぐやるから解除">
                                                                    <Path Data="M 9,0 L 2,10 L 7,10 L 5,18 L 13,8 L 8,8 Z"
                                                                          Fill="{x:Bind local:MainWindow.GetJustDoItFillBrush(IsJustDoIt), Mode=OneWay}"
                                                                          Stroke="{x:Bind local:MainWindow.GetJustDoItStrokeBrush(IsJustDoIt), Mode=OneWay}"
                                                                          StrokeThickness="1.2"
                                                                          Width="11" Height="11" Stretch="Uniform"
                                                                          HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                </Button>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>

                        <!-- タグビュー (Tags - 左) -->
                        <Grid x:Name="TagsViewContainer" Grid.Row="1" Visibility="Collapsed" RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            
                            <TextBox x:Name="SidebarTagSearchBox" 
                                     Grid.Row="0"
                                     PlaceholderText="Search tags..."
                                     HorizontalAlignment="Stretch"
                                     TextChanged="SidebarTagSearchBox_TextChanged">
                                <TextBox.Resources>
                                    <SolidColorBrush x:Key="TextControlBackground" Color="White" Opacity="0.06" />
                                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="White" Opacity="0.10" />
                                    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="White" Opacity="0.14" />
                                    <SolidColorBrush x:Key="TextControlBorderBrush" Color="White" Opacity="0.10" />
                                    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="White" Opacity="0.15" />
                                    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="White" Opacity="0.30" />
                                    <SolidColorBrush x:Key="TextControlForeground" Color="#ffffff" />
                                    <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#777777" />
                                </TextBox.Resources>
                            </TextBox>
                            
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <StackPanel Spacing="4" x:Name="LeftTagsListContainer">
                                    <!-- Dynamic items will be populated in code-behind -->
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Grid>
                    <!-- リサイズ用スプリッター領域 -->
                    <local:ResizableGrid Grid.Column="2" 
                                         Width="6" 
                                         Background="Transparent" 
                                         PointerPressed="Resizer_PointerPressed"
                                         PointerMoved="Resizer_PointerMoved"
                                         PointerReleased="Resizer_PointerReleased" />
                </Grid>
            </SplitView.Pane>

            <!-- メインコンテンツ領域 -->
            <SplitView.Content>
                <SplitView x:Name="RightSidebarSplitView"
                           DisplayMode="CompactOverlay"
                           CompactPaneLength="48"
                           OpenPaneLength="320"
                           IsPaneOpen="False"
                           PaneBackground="{StaticResource SidebarBackgroundBrush}"
                           PaneClosed="RightSidebarSplitView_PaneClosed"
                           PaneOpened="RightSidebarSplitView_PaneOpened"
                           PaneOpening="RightSidebarSplitView_PaneOpening"
                           PaneClosing="RightSidebarSplitView_PaneClosing"
                           PanePlacement="Right">
                    <SplitView.Pane>
                        <Grid HorizontalAlignment="Right" Width="{Binding ElementName=RightSidebarSplitView, Path=OpenPaneLength}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="48" />
                            </Grid.ColumnDefinitions>

                            <local:ResizableGrid Grid.Column="0" 
                                                 Width="6" 
                                                 Background="Transparent" 
                                                 PointerPressed="RightResizer_PointerPressed"
                                                 PointerMoved="RightResizer_PointerMoved"
                                                 PointerReleased="RightResizer_PointerReleased" />

                            <Grid Grid.Column="1" Background="Transparent" Margin="12,8,12,12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="4,0,-8,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="RightPaneTitleTextBlock" Grid.Column="0" Text="Just Do It" FontSize="15" FontWeight="SemiBold" Foreground="#ffffff" VerticalAlignment="Center" />
                                    <ToggleButton x:Name="RightDeleteModeButton" Grid.Column="1"
                                                  Style="{StaticResource IconToggleButtonStyle}"
                                                  Width="32" Height="32"
                                                  Margin="0,0,4,0"
                                                  Visibility="Collapsed"
                                                  ToolTipService.ToolTip="削除モード">
                                        <FontIcon Glyph="&#xE74D;" FontFamily="Segoe Fluent Icons" FontSize="12" Foreground="#ffffff" />
                                    </ToggleButton>
                                    <ToggleButton x:Name="PinRightSidebarButton" Grid.Column="2"
                                                  Style="{StaticResource IconToggleButtonStyle}"
                                                  Width="32" Height="32"
                                                  Click="PinRightSidebarButton_Click"
                                                  ToolTipService.ToolTip="サイドバーを固定">
                                        <ToggleButton.Resources>
                                            <SolidColorBrush x:Key="ToggleButtonBackground" Color="Transparent" />
                                            <SolidColorBrush x:Key="ToggleButtonBackgroundPointerOver" Color="#22FFFFFF" />
                                            <SolidColorBrush x:Key="ToggleButtonBackgroundPressed" Color="#33FFFFFF" />
                                            <SolidColorBrush x:Key="ToggleButtonBorderBrush" Color="Transparent" />
                                            <SolidColorBrush x:Key="ToggleButtonBorderBrushPointerOver" Color="Transparent" />
                                            <SolidColorBrush x:Key="ToggleButtonBorderBrushPressed" Color="Transparent" />
                                            <SolidColorBrush x:Key="ToggleButtonBackgroundChecked" Color="Transparent" />
                                            <SolidColorBrush x:Key="ToggleButtonBackgroundCheckedPointerOver" Color="#22FFFFFF" />
                                            <SolidColorBrush x:Key="ToggleButtonBackgroundCheckedPressed" Color="#33FFFFFF" />
                                            <SolidColorBrush x:Key="ToggleButtonBorderBrushChecked" Color="Transparent" />
                                            <SolidColorBrush x:Key="ToggleButtonBorderBrushCheckedPointerOver" Color="Transparent" />
                                            <SolidColorBrush x:Key="ToggleButtonBorderBrushCheckedPressed" Color="Transparent" />
                                            <SolidColorBrush x:Key="ToggleButtonForeground" Color="#ffffff" />
                                            <SolidColorBrush x:Key="ToggleButtonForegroundPointerOver" Color="#ffffff" />
                                            <SolidColorBrush x:Key="ToggleButtonForegroundPressed" Color="#ffffff" />
                                            <SolidColorBrush x:Key="ToggleButtonForegroundChecked" Color="#ffffff" />
                                            <SolidColorBrush x:Key="ToggleButtonForegroundCheckedPointerOver" Color="#ffffff" />
                                            <SolidColorBrush x:Key="ToggleButtonForegroundCheckedPressed" Color="#ffffff" />
                                        </ToggleButton.Resources>
                                        <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <FontIcon Glyph="&#xE718;" FontFamily="Segoe Fluent Icons" FontSize="12" Foreground="#ffffff" />
                                            <FontIcon x:Name="RightSidebarPinFilledIcon" Glyph="&#xE841;" FontFamily="Segoe Fluent Icons" FontSize="12" Foreground="#ffffff" Visibility="Collapsed" />
                                        </Grid>
                                    </ToggleButton>
                                </Grid>

                                <!-- メモ一覧ビュー (右) -->
                                <Grid x:Name="RightNotesViewContainer" Grid.Row="1" Visibility="Collapsed" RowSpacing="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    
                                    <TextBox x:Name="RightSidebarNoteSearchBox" 
                                             Grid.Row="0"
                                             PlaceholderText="Search for notes..."
                                             HorizontalAlignment="Stretch"
                                             TextChanged="RightSidebarNoteSearchBox_TextChanged"
                                             KeyDown="RightSidebarNoteSearchBox_KeyDown">
                                        <TextBox.Resources>
                                            <SolidColorBrush x:Key="TextControlBackground" Color="White" Opacity="0.06" />
                                            <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="White" Opacity="0.10" />
                                            <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="White" Opacity="0.14" />
                                            <SolidColorBrush x:Key="TextControlBorderBrush" Color="White" Opacity="0.10" />
                                            <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="White" Opacity="0.15" />
                                            <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="White" Opacity="0.30" />
                                            <SolidColorBrush x:Key="TextControlForeground" Color="#ffffff" />
                                            <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="#ffffff" />
                                            <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#ffffff" />
                                            <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#777777" />
                                            <SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver" Color="#777777" />
                                            <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="#777777" />
                                        </TextBox.Resources>
                                    </TextBox>

                                    <Grid Grid.Row="1" x:Name="RightSidebarActiveTagFilterGrid" Visibility="Collapsed" Margin="0,4,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Background="#1f1f1f" CornerRadius="10" Padding="8,4" BorderBrush="#333333" BorderThickness="1" HorizontalAlignment="Left">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <FontIcon Glyph="&#xE8EC;" FontSize="11" Foreground="#0078d4" VerticalAlignment="Center" />
                                                <TextBlock x:Name="RightSidebarActiveTagFilterTextBlock" FontSize="11" Foreground="#ffffff" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Border>
                                        <Button Grid.Column="1" Content="&#xE10A;" Style="{StaticResource IconButtonStyle}" Width="24" Height="24" FontSize="10" Click="ClearRightSidebarActiveTagFilter_Click" ToolTipService.ToolTip="フィルターを解除" />
                                    </Grid>
                                    
                                    <ScrollViewer x:Name="RightSidebarNotesScrollViewer" Grid.Row="2" VerticalScrollBarVisibility="Auto">
                                        <StackPanel x:Name="RightSidebarNotesListContainer" Spacing="8">
                                            <!-- Recent セクション -->
                                            <StackPanel x:Name="RightSidebarRecentSection" Spacing="4">
                                                <TextBlock Text="Recent" FontSize="11" Foreground="#666666" FontWeight="SemiBold" Margin="4,4,0,2" />
                                                <ItemsControl x:Name="RightSidebarRecentListView" ItemTemplate="{StaticResource NoteItemTemplate}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Spacing="2" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                </ItemsControl>
                                            </StackPanel>

                                            <!-- Pinned セクション -->
                                            <StackPanel x:Name="RightSidebarPinnedSection" Spacing="4">
                                                <TextBlock Text="Pinned" FontSize="11" Foreground="#666666" FontWeight="SemiBold" Margin="4,4,0,2" />
                                                <ItemsControl x:Name="RightSidebarPinnedListView" ItemTemplate="{StaticResource NoteItemTemplate}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Spacing="2" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                </ItemsControl>
                                            </StackPanel>
                                            
                                            <!-- Notes セクション -->
                                            <StackPanel x:Name="RightSidebarNotesSection" Spacing="4">
                                                <TextBlock Text="Notes" FontSize="11" Foreground="#666666" FontWeight="SemiBold" Margin="4,4,0,2" />
                                                <ItemsControl x:Name="RightSidebarNotesListView" ItemTemplate="{StaticResource NoteItemTemplate}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Spacing="2" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                </ItemsControl>
                                            </StackPanel>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Grid>

                                <!-- 現在のタスクビュー (右) -->
                                <Grid x:Name="RightTasksViewContainer" Grid.Row="1" Visibility="Collapsed" RowSpacing="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    
                                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl x:Name="RightCurrentTasksListView">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Spacing="2" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="local:TaskItemViewModel">
                                                    <Grid Padding="4,2" CornerRadius="4" Background="Transparent"
                                                          PointerEntered="TaskItemGrid_PointerEntered"
                                                          PointerExited="TaskItemGrid_PointerExited">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        
                                                        <CheckBox Grid.Column="0" IsChecked="{x:Bind IsCompleted, Mode=TwoWay}" MinWidth="32" VerticalAlignment="Center" Margin="0,0,4,0" />
                                                        
                                                         <Grid Grid.Column="1" VerticalAlignment="Center">
                                                             <TextBlock x:Name="RightCurrentTaskTitleTextBlock"
                                                                        Text="{x:Bind Title, Mode=OneWay}"
                                                                        FontSize="13" Foreground="#ffffff"
                                                                        VerticalAlignment="Center"
                                                                        TextTrimming="CharacterEllipsis"
                                                                        TextWrapping="NoWrap"
                                                                        Tapped="RightCurrentTaskTitleTextBlock_Tapped"
                                                                        ToolTipService.ToolTip="{x:Bind Title, Mode=OneWay}" />
                                                             <TextBox x:Name="RightCurrentTaskTitleTextBox"
                                                                      Text="{x:Bind Title, Mode=TwoWay}"
                                                                      FontSize="13" Foreground="#ffffff"
                                                                      VerticalAlignment="Center"
                                                                      BorderThickness="0" Background="Transparent"
                                                                      Padding="0,4"
                                                                      TextWrapping="NoWrap"
                                                                      Visibility="Collapsed"
                                                                      LostFocus="RightCurrentTaskTitleTextBox_LostFocus"
                                                                      KeyDown="RightCurrentTaskTitleTextBox_KeyDown">
                                                                 <TextBox.Resources>
                                                                     <SolidColorBrush x:Key="TextControlBackground" Color="Transparent" />
                                                                     <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent" />
                                                                     <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#252525" />
                                                                     <SolidColorBrush x:Key="TextControlBorderBrush" Color="Transparent" />
                                                                     <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent" />
                                                                     <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#333333" />
                                                                     <SolidColorBrush x:Key="TextControlForeground" Color="#ffffff" />
                                                                     <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="#ffffff" />
                                                                     <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#ffffff" />
                                                                 </TextBox.Resources>
                                                             </TextBox>
                                                         </Grid>
                                                        
                                                        <Button x:Name="JustDoItTaskButton"
                                                                Grid.Column="2"
                                                                Style="{StaticResource IconButtonStyle}"
                                                                Width="28" Height="28"
                                                                Visibility="{x:Bind local:MainWindow.BoolToVisibility(IsJustDoIt), Mode=OneWay}"
                                                                Loaded="JustDoItTaskButton_Loaded"
                                                                Unloaded="JustDoItTaskButton_Unloaded"
                                                                ToolTipService.ToolTip="すぐやるに追加/解除">
                                                            <Path Data="M 9,0 L 2,10 L 7,10 L 5,18 L 13,8 L 8,8 Z"
                                                                  Fill="{x:Bind local:MainWindow.GetJustDoItFillBrush(IsJustDoIt), Mode=OneWay}"
                                                                  Stroke="{x:Bind local:MainWindow.GetJustDoItStrokeBrush(IsJustDoIt), Mode=OneWay}"
                                                                  StrokeThickness="1.2"
                                                                  Width="11" Height="11" Stretch="Uniform"
                                                                  HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </Button>
                                                        
                                                        <Button x:Name="DeleteTaskButton"
                                                                Grid.Column="3" Content="&#xE74D;"
                                                                Style="{StaticResource IconButtonStyle}"
                                                                Width="28" Height="28" FontSize="11"
                                                                Foreground="#FF453A"
                                                                Visibility="{Binding ElementName=RightDeleteModeButton, Path=IsChecked, Converter={StaticResource BoolToVisibilityConverter}}"
                                                                Loaded="DeleteTaskButton_Loaded"
                                                                Unloaded="DeleteTaskButton_Unloaded"
                                                                ToolTipService.ToolTip="タスクを削除" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>

                                    <TextBox x:Name="RightAddTaskBox"
                                             Grid.Row="1"
                                             PlaceholderText="Add task..."
                                             BorderThickness="0,1,0,0"
                                             CornerRadius="0"
                                             Padding="4,8"
                                             KeyDown="RightAddTaskBox_KeyDown">
                                        <TextBox.Resources>
                                            <SolidColorBrush x:Key="TextControlBackground" Color="Transparent" />
                                            <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent" />
                                            <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent" />
                                            <SolidColorBrush x:Key="TextControlBorderBrush" Color="#2d2d2d" />
                                            <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#2d2d2d" />
                                            <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#2d2d2d" />
                                            <SolidColorBrush x:Key="TextControlForeground" Color="#ffffff" />
                                            <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#555555" />
                                        </TextBox.Resources>
                                    </TextBox>
                                </Grid>

                                <!-- すべてのタスクビュー (右) -->
                                <Grid x:Name="RightAllTasksViewContainer" Grid.Row="1" Visibility="Collapsed" RowSpacing="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    
                                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl x:Name="RightAllTasksGroupsControl">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Spacing="16" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="local:AllTasksGroupViewModel">
                                                    <StackPanel Spacing="4">
                                                        <Button Content="{x:Bind NoteTitle}"
                                                                Background="#002D2D2D"
                                                                BorderThickness="0"
                                                                Foreground="#0078d4"
                                                                FontWeight="SemiBold"
                                                                FontSize="12"
                                                                Padding="4,2"
                                                                HorizontalAlignment="Left"
                                                                Click="AllTasksGroupHeader_Click"
                                                                DataContext="{x:Bind}" />
                                                        
                                                        <ItemsControl ItemsSource="{x:Bind Tasks}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <StackPanel Spacing="2" />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate x:DataType="local:TaskItemViewModel">
                                                                    <Grid Padding="4,2" Background="Transparent"
                                                                          PointerPressed="AllTaskItem_PointerPressed"
                                                                          PointerEntered="AllTaskItemGrid_PointerEntered"
                                                                          PointerExited="AllTaskItemGrid_PointerExited">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="Auto" />
                                                                            <ColumnDefinition Width="*" />
                                                                            <ColumnDefinition Width="Auto" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <CheckBox Grid.Column="0" IsChecked="{x:Bind IsCompleted, Mode=TwoWay}" MinWidth="32" VerticalAlignment="Center" Margin="0,0,4,0" />
                                                                        <TextBlock Grid.Column="1" Text="{x:Bind Title}" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{x:Bind Title, Mode=OneWay}" />
                                                                        
                                                                        <Button x:Name="AllJustDoItButton"
                                                                                Style="{StaticResource IconButtonStyle}"
                                                                                Width="28" Height="28"
                                                                                Visibility="{x:Bind local:MainWindow.BoolToVisibility(IsJustDoIt), Mode=OneWay}"
                                                                                Loaded="AllJustDoItButton_Loaded"
                                                                                Unloaded="AllJustDoItButton_Unloaded"
                                                                                ToolTipService.ToolTip="すぐやるに追加/解除">
                                                                            <Path Data="M 9,0 L 2,10 L 7,10 L 5,18 L 13,8 L 8,8 Z"
                                                                                  Fill="{x:Bind local:MainWindow.GetJustDoItFillBrush(IsJustDoIt), Mode=OneWay}"
                                                                                  Stroke="{x:Bind local:MainWindow.GetJustDoItStrokeBrush(IsJustDoIt), Mode=OneWay}"
                                                                                  StrokeThickness="1.2"
                                                                                  Width="11" Height="11" Stretch="Uniform"
                                                                                  HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                        </Button>
                                                                    </Grid>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>

                                <Grid x:Name="RightJustDoItTasksViewContainer" Grid.Row="1" Visibility="Collapsed" RowSpacing="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    
                                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl x:Name="JustDoItTasksGroupsControl">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Spacing="16" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="local:AllTasksGroupViewModel">
                                                    <StackPanel Spacing="4">
                                                        <Button Content="{x:Bind NoteTitle}"
                                                                Background="#002D2D2D"
                                                                BorderThickness="0"
                                                                Foreground="#0078d4"
                                                                FontWeight="SemiBold"
                                                                FontSize="12"
                                                                Padding="4,2"
                                                                HorizontalAlignment="Left"
                                                                Click="AllTasksGroupHeader_Click"
                                                                DataContext="{x:Bind}" />
                                                        
                                                        <ItemsControl ItemsSource="{x:Bind Tasks}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <StackPanel Spacing="2" />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate x:DataType="local:TaskItemViewModel">
                                                                    <Grid Padding="4,2" Background="Transparent"
                                                                          PointerPressed="AllTaskItem_PointerPressed"
                                                                          PointerEntered="JustDoItTaskItemGrid_PointerEntered"
                                                                          PointerExited="JustDoItTaskItemGrid_PointerExited">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="Auto" />
                                                                            <ColumnDefinition Width="*" />
                                                                            <ColumnDefinition Width="Auto" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <CheckBox Grid.Column="0" IsChecked="{x:Bind IsCompleted, Mode=TwoWay}" MinWidth="32" VerticalAlignment="Center" Margin="0,0,4,0" />
                                                                        <TextBlock Grid.Column="1" Text="{x:Bind Title}" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{x:Bind Title, Mode=OneWay}" />
                                                                        
                                                                        <Button x:Name="JustDoItToggleBtn"
                                                                                Grid.Column="2"
                                                                                Style="{StaticResource IconButtonStyle}"
                                                                                Width="28" Height="28"
                                                                                Visibility="Collapsed"
                                                                                Loaded="JustDoItToggleBtn_Loaded"
                                                                                Unloaded="JustDoItToggleBtn_Unloaded"
                                                                                ToolTipService.ToolTip="すぐやるから解除">
                                                                            <Path Data="M 9,0 L 2,10 L 7,10 L 5,18 L 13,8 L 8,8 Z"
                                                                                  Fill="{x:Bind local:MainWindow.GetJustDoItFillBrush(IsJustDoIt), Mode=OneWay}"
                                                                                  Stroke="{x:Bind local:MainWindow.GetJustDoItStrokeBrush(IsJustDoIt), Mode=OneWay}"
                                                                                  StrokeThickness="1.2"
                                                                                  Width="11" Height="11" Stretch="Uniform"
                                                                                  HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                        </Button>
                                                                    </Grid>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>

                                <!-- タグビュー (右) -->
                                <Grid x:Name="RightTagsViewContainer" Grid.Row="1" Visibility="Collapsed" RowSpacing="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    
                                    <TextBox x:Name="RightSidebarTagSearchBox" 
                                             Grid.Row="0"
                                             PlaceholderText="Search tags..."
                                             HorizontalAlignment="Stretch"
                                             TextChanged="RightSidebarTagSearchBox_TextChanged">
                                        <TextBox.Resources>
                                            <SolidColorBrush x:Key="TextControlBackground" Color="White" Opacity="0.06" />
                                            <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="White" Opacity="0.10" />
                                            <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="White" Opacity="0.14" />
                                            <SolidColorBrush x:Key="TextControlBorderBrush" Color="White" Opacity="0.10" />
                                            <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="White" Opacity="0.15" />
                                            <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="White" Opacity="0.30" />
                                            <SolidColorBrush x:Key="TextControlForeground" Color="#ffffff" />
                                            <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#777777" />
                                        </TextBox.Resources>
                                    </TextBox>
                                    
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                        <StackPanel Spacing="4" x:Name="RightTagsListContainer">
                                            <!-- Dynamic items populated in code-behind -->
                                        </StackPanel>
                                    </ScrollViewer>
                                </Grid>
                            </Grid>

                            <Grid Grid.Column="2" Background="Transparent" BorderBrush="#2d2d2d" BorderThickness="1,0,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Button x:Name="RightHamburgerButton"
                                        Grid.Row="0"
                                        Content="&#xE700;"
                                        Style="{StaticResource IconButtonStyle}"
                                        Width="36" Height="36"
                                        HorizontalAlignment="Center"
                                        Margin="0,8,0,0"
                                        Click="RightHamburgerButton_Click"
                                        ToolTipService.ToolTip="ナビゲーションの開閉" />

                                <StackPanel Grid.Row="1" Spacing="8" Margin="0,16,0,0">
                                    <!-- メモ一覧 (右) -->
                                    <Grid x:Name="RightNotesMenuGrid">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="3" />
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="RightNotesMenuButton"
                                                Grid.Column="0"
                                                Content="&#xEE40;"
                                                Style="{StaticResource IconButtonStyle}"
                                                Width="36" Height="36"
                                                HorizontalAlignment="Center"
                                                Click="RightNotesMenuButton_Click"
                                                ToolTipService.ToolTip="メモ一覧" />
                                        <Border x:Name="RightNotesActiveIndicator" Grid.Column="1" Width="3" Height="16" Background="#0078d4" CornerRadius="1.5" VerticalAlignment="Center" Visibility="Collapsed" />
                                    </Grid>

                                    <!-- 現在のタスク (右) -->
                                    <Grid x:Name="RightTasksMenuGrid">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="3" />
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="RightTasksMenuButton"
                                                Grid.Column="0"
                                                Content="&#xE73E;"
                                                Style="{StaticResource IconButtonStyle}"
                                                Width="36" Height="36"
                                                HorizontalAlignment="Center"
                                                Click="RightTasksMenuButton_Click"
                                                ToolTipService.ToolTip="現在のタスク" />
                                        <Border x:Name="RightTasksActiveIndicator" Grid.Column="1" Width="3" Height="16" Background="#0078d4" CornerRadius="1.5" VerticalAlignment="Center" Visibility="Collapsed" />
                                    </Grid>

                                    <!-- すべてのタスク (右) -->
                                    <Grid x:Name="RightAllTasksMenuGrid">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="3" />
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="RightAllTasksMenuButton"
                                                Grid.Column="0"
                                                Content="&#xE9D5;"
                                                Style="{StaticResource IconButtonStyle}"
                                                Width="36" Height="36"
                                                HorizontalAlignment="Center"
                                                Click="RightAllTasksMenuButton_Click"
                                                ToolTipService.ToolTip="すべてのタスク" />
                                        <Border x:Name="RightAllTasksActiveIndicator" Grid.Column="1" Width="3" Height="16" Background="#0078d4" CornerRadius="1.5" VerticalAlignment="Center" Visibility="Collapsed" />
                                    </Grid>

                                    <!-- すぐやる (右) -->
                                    <Grid x:Name="RightJustDoItMenuGrid">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="3" />
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="RightJustDoItMenuButton"
                                                Grid.Column="0"
                                                Content="&#xE945;"
                                                Style="{StaticResource IconButtonStyle}"
                                                Width="36" Height="36"
                                                HorizontalAlignment="Center"
                                                Click="RightJustDoItMenuButton_Click"
                                                ToolTipService.ToolTip="すぐやる (Just Do It)" />
                                        <Border x:Name="RightJustDoItActiveIndicator" Grid.Column="1" Width="3" Height="16" Background="#0078d4" CornerRadius="1.5" VerticalAlignment="Center" Visibility="Collapsed" />
                                    </Grid>

                                    <!-- タグ (右) -->
                                    <Grid x:Name="RightTagsMenuGrid">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="3" />
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="RightTagsMenuButton"
                                                Grid.Column="0"
                                                Content="&#xE8EC;"
                                                Style="{StaticResource IconButtonStyle}"
                                                Width="36" Height="36"
                                                HorizontalAlignment="Center"
                                                Click="RightTagsMenuButton_Click"
                                                ToolTipService.ToolTip="タグ" />
                                        <Border x:Name="RightTagsActiveIndicator" Grid.Column="1" Width="3" Height="16" Background="#0078d4" CornerRadius="1.5" VerticalAlignment="Center" Visibility="Collapsed" />
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </SplitView.Pane>

                    <SplitView.Content>
                        <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" /> <!-- 新規ヘッダー部 -->
                        <RowDefinition Height="*" />    <!-- エディタ -->
                        <RowDefinition Height="Auto" /> <!-- ステータスバー -->
                    </Grid.RowDefinitions>

                    <!-- ヘッダー部 -->
                    <Grid Grid.Row="0" Height="36" BorderBrush="#2d2d2d" BorderThickness="0,0,0,1" Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" /> <!-- 操作ボタン群 -->
                            <ColumnDefinition Width="*" />    <!-- タイトル表示 -->
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0" Spacing="4">
                            <!-- メモ一覧ボタン -->
                            <Button x:Name="NotesButton" Content="&#xEE40;" Style="{StaticResource IconButtonStyle}" ToolTipService.ToolTip="メモ一覧">
                                <Button.Flyout>
                                    <Flyout x:Name="NotesFlyout" Placement="BottomEdgeAlignedLeft" Opened="NotesFlyout_Opened" Closed="NotesFlyout_Closed">
                                        <Flyout.FlyoutPresenterStyle>
                                            <Style TargetType="FlyoutPresenter">
                                                <Setter Property="Background" Value="{StaticResource OpaqueFlyoutBackgroundBrush}" />
                                                <Setter Property="BorderBrush" Value="#333333" />
                                                <Setter Property="BorderThickness" Value="1" />
                                                <Setter Property="CornerRadius" Value="8" />
                                                <Setter Property="Padding" Value="12" />
                                                <Setter Property="MaxWidth" Value="320" />
                                                <Setter Property="MinWidth" Value="280" />
                                                <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled" />
                                                <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
                                            </Style>
                                        </Flyout.FlyoutPresenterStyle>
                                        
                                        <Grid RowSpacing="8" Width="260">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" /> <!-- 検索ボックス -->
                                                <RowDefinition Height="*" />    <!-- メモ一覧スクロール領域 -->
                                            </Grid.RowDefinitions>
                                            
                                            <!-- 検索ボックス -->
                                            <TextBox x:Name="NoteSearchBox" 
                                                     Grid.Row="0"
                                                     PlaceholderText="Search for notes..."
                                                     Width="260"
                                                     HorizontalAlignment="Stretch"
                                                     TextChanged="NoteSearchBox_TextChanged"
                                                     KeyDown="NoteSearchBox_KeyDown">
                                                <TextBox.Resources>
                                                    <!-- ダークテーマ用TextBoxスタイルオーバーライド -->
                                                    <SolidColorBrush x:Key="TextControlBackground" Color="#252525" />
                                                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#2d2d2d" />
                                                    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#2d2d2d" />
                                                    <SolidColorBrush x:Key="TextControlBorderBrush" Color="#333333" />
                                                    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#444444" />
                                                    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#0078d4" />
                                                    <SolidColorBrush x:Key="TextControlForeground" Color="#ffffff" />
                                                    <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="#ffffff" />
                                                    <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#ffffff" />
                                                    <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#777777" />
                                                    <SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver" Color="#777777" />
                                                    <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="#777777" />
                                                </TextBox.Resources>
                                            </TextBox>
                                            
                                            <!-- 一覧スクロール領域 -->
                                            <ScrollViewer x:Name="NotesScrollViewer" Grid.Row="1" MaxHeight="300" VerticalScrollBarVisibility="Auto">
                                                <StackPanel x:Name="NotesListContainer" Spacing="8">
                                                    <!-- Recent セクション -->
                                                    <StackPanel x:Name="RecentSection" Spacing="4">
                                                        <TextBlock Text="Recent" FontSize="11" Foreground="#666666" FontWeight="SemiBold" Margin="4,4,0,2" />
                                                        <ItemsControl x:Name="RecentListView" ItemTemplate="{StaticResource NoteItemTemplate}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <StackPanel Spacing="2" />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                        </ItemsControl>
                                                    </StackPanel>

                                                    <!-- Pinned セクション -->
                                                    <StackPanel x:Name="PinnedSection" Spacing="4">
                                                        <TextBlock Text="Pinned" FontSize="11" Foreground="#666666" FontWeight="SemiBold" Margin="4,4,0,2" />
                                                        <ItemsControl x:Name="PinnedListView" ItemTemplate="{StaticResource NoteItemTemplate}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <StackPanel Spacing="2" />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                    
                                                    <!-- Notes セクション -->
                                                    <StackPanel x:Name="NotesSection" Spacing="4">
                                                        <TextBlock Text="Notes" FontSize="11" Foreground="#666666" FontWeight="SemiBold" Margin="4,4,0,2" />
                                                        <ItemsControl x:Name="NotesListView" ItemTemplate="{StaticResource NoteItemTemplate}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <StackPanel Spacing="2" />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </StackPanel>
                                            </ScrollViewer>
                                        </Grid>
                                    </Flyout>
                                </Button.Flyout>
                            </Button>

                            <!-- 新規追加ボタン -->
                            <Button x:Name="NewButton" Content="&#xE710;" Style="{StaticResource IconButtonStyle}" ToolTipService.ToolTip="新規作成" Click="NewButton_Click" />

                            <!-- 空行削除用セパレータとボタン -->
                            <Border Width="1" Height="16" Background="#333333" Margin="4,0" />
                            <Button x:Name="RemoveEmptyLinesHeaderButton" Content="&#xED60;" Style="{StaticResource IconButtonStyle}" ToolTipService.ToolTip="空行を削除" Click="RemoveEmptyLines_Click" />

                            <!-- AIリライト用セパレータとボタン -->
                            <Border Width="1" Height="16" Background="#333333" Margin="4,0" />
                            <Button x:Name="AiRewriteButton" Content="&#xE9D9;" FontFamily="Segoe Fluent Icons" Style="{StaticResource IconButtonStyle}" ToolTipService.ToolTip="AIでリライト">
                                <Button.Flyout>
                                    <MenuFlyout x:Name="AiRewriteMenuFlyout" Opened="AiRewriteMenuFlyout_Opened" />
                                </Button.Flyout>
                            </Button>
                            <Button x:Name="AiRunButton" Content="&#xE768;" FontFamily="Segoe Fluent Icons" Style="{StaticResource IconButtonStyle}" ToolTipService.ToolTip="AIで実行" Click="AiRunButton_Click" />
                            <Button x:Name="AiTaskGenButton" Content="&#xE73E;" FontFamily="Segoe Fluent Icons" Style="{StaticResource IconButtonStyle}" ToolTipService.ToolTip="AIでタスクを生成" Click="AiTaskGenButton_Click" />

                            <!-- タグ管理用セパレータとボタン -->
                            <Border Width="1" Height="16" Background="#333333" Margin="4,0" />
                            <Button x:Name="ManageTagsButton" Content="&#xE710;" FontFamily="Segoe Fluent Icons" Style="{StaticResource IconButtonStyle}" ToolTipService.ToolTip="タグの管理">
                                <Button.Flyout>
                                    <Flyout x:Name="ManageTagsFlyout" Opened="ManageTagsFlyout_Opened" ShouldConstrainToRootBounds="True">
                                        <Flyout.SystemBackdrop>
                                            <DesktopAcrylicBackdrop />
                                        </Flyout.SystemBackdrop>
                                        <Flyout.FlyoutPresenterStyle>
                                            <Style TargetType="FlyoutPresenter">
                                                <Setter Property="Background" Value="{StaticResource FlyoutBackgroundBrush}" />
                                                <Setter Property="BorderBrush" Value="#333333" />
                                                <Setter Property="BorderThickness" Value="1" />
                                                <Setter Property="CornerRadius" Value="8" />
                                                <Setter Property="Padding" Value="12" />
                                                <Setter Property="MaxWidth" Value="320" />
                                                <Setter Property="MinWidth" Value="260" />
                                            </Style>
                                        </Flyout.FlyoutPresenterStyle>
                                        
                                        <Grid RowSpacing="8" Width="240">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" /> <!-- 新規追加TextBox -->
                                                <RowDefinition Height="Auto" /> <!-- 区切り・ラベル -->
                                                <RowDefinition Height="*" />    <!-- タグチェックリスト -->
                                            </Grid.RowDefinitions>
                                            
                                            <Grid Grid.Row="0" ColumnSpacing="6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBox x:Name="NewTagTextBox" PlaceholderText="New tag..." Height="28" Padding="6,2" VerticalContentAlignment="Center" KeyDown="NewTagTextBox_KeyDown" />
                                                <Button Grid.Column="1" Content="Add" Click="AddTag_Click" Height="28" Padding="12,0" FontSize="11" CornerRadius="4" />
                                            </Grid>
                                            
                                            <TextBlock Grid.Row="1" Text="Tags" FontSize="11" Foreground="#666666" FontWeight="SemiBold" Margin="0,4,0,2" />
                                            
                                            <ScrollViewer Grid.Row="2" MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                                <StackPanel x:Name="ManageTagsListContainer" Spacing="4">
                                                    <!-- Dynamic tags with checkboxes populated in code-behind -->
                                                </StackPanel>
                                            </ScrollViewer>
                                        </Grid>
                                    </Flyout>
                                </Button.Flyout>
                            </Button>

                            <!-- タグ表示領域 -->
                            <StackPanel x:Name="HeaderTagsPanel" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" Margin="8,0,0,0">
                                <!-- タグチップはコードビハインドから動的生成します -->
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <!-- エディタ -->
                    <Grid Grid.Row="1">
                        <RichEditBox 
                            x:Name="MemoTextBox"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            BorderThickness="0"
                            Padding="16,12,16,12"
                            FontSize="14"
                            FontFamily="Noto Sans JP, Yu Gothic UI"
                            IsSpellCheckEnabled="False"
                            IsTextPredictionEnabled="False"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            ScrollViewer.HorizontalScrollBarVisibility="Auto"
                            TextChanged="MemoTextBox_TextChanged"
                            SelectionChanged="MemoTextBox_SelectionChanged"
                            PreviewKeyDown="MemoTextBox_PreviewKeyDown"
                            SelectionFlyout="{x:Null}"
                            SelectionHighlightColor="#660078D4"
                            SelectionHighlightColorWhenNotFocused="#660078D4">
                            
                            <RichEditBox.ContextFlyout>
                                <MenuFlyout Opening="MemoTextBox_ContextFlyout_Opening" />
                            </RichEditBox.ContextFlyout>

                            <RichEditBox.Resources>
                                <SolidColorBrush x:Key="TextControlBackground" Color="Transparent" />
                                <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent" />
                                <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent" />
                                <SolidColorBrush x:Key="TextControlBorderBrush" Color="Transparent" />
                                <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent" />
                                <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent" />
                                <Thickness x:Key="TextControlBorderThemeThickness">0</Thickness>
                                <Thickness x:Key="TextControlBorderThemeThicknessFocused">0</Thickness>
                            </RichEditBox.Resources>
                        </RichEditBox>
                        
                        <TextBlock
                            x:Name="PlaceholderTextBlock"
                            Text="Start writing..."
                            Foreground="#555555"
                            FontSize="14"
                            FontFamily="Noto Sans JP, Yu Gothic UI"
                            Padding="16,12,16,12"
                            IsHitTestVisible="False"
                            VerticalAlignment="Top"
                            HorizontalAlignment="Left" />

                        <!-- 検索置換パネル: Popup は ShouldConstrainToRootBounds=False 時に別 HWND になり
                             IME が動作しないため、Canvas + Border でフローティング実装する -->
                        <Canvas x:Name="FindReplaceCanvas"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch">
                        <Border x:Name="FindReplacePanel"
                                Canvas.Left="0"
                                Canvas.Top="12"
                                BorderBrush="#333333"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="8"
                                Width="290"
                                Visibility="Collapsed">
                                <Border.Background>
                                    <!-- 同一 HWND 内描画のため AcrylicBrush 使用可能だが、
                                         視認性のためやや不透明な SolidColorBrush を使用 -->
                                    <SolidColorBrush Color="#1e1e1e" Opacity="0.5" />
                                </Border.Background>
                                <Border.Shadow>
                                    <ThemeShadow />
                                </Border.Shadow>
                                <StackPanel Spacing="4">
                                    <!-- ドラッグハンドル兼ヘッダー -->
                                    <Grid x:Name="DragHandle"
                                          Background="Transparent"
                                          Height="24"
                                          Margin="0,0,0,2"
                                          PointerPressed="FindReplacePanel_PointerPressed"
                                          PointerMoved="FindReplacePanel_PointerMoved"
                                          PointerReleased="FindReplacePanel_PointerReleased"
                                          PointerEntered="FindReplacePanel_PointerEntered"
                                          PointerExited="FindReplacePanel_PointerExited">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                            <TextBlock Text="&#xE76F;" FontFamily="Segoe Fluent Icons" FontSize="10" Foreground="#888888" VerticalAlignment="Center" Margin="2,0,0,0" />
                                            <TextBlock Text="検索と置換" FontSize="11" Foreground="#888888" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        </StackPanel>

                                        <Button Grid.Column="1"
                                                Content="&#xE10A;"
                                                FontFamily="Segoe Fluent Icons"
                                                FontSize="8"
                                                Style="{StaticResource IconButtonStyle}"
                                                Width="20"
                                                Height="20"
                                                Click="CloseFindReplace_Click"
                                                ToolTipService.ToolTip="閉じる" />
                                    </Grid>

                                    <Grid ColumnSpacing="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <ToggleButton x:Name="ToggleReplaceModeBtn" Grid.Column="0" Content="&#xE10C;" Style="{StaticResource IconToggleButtonStyle}" Width="28" Height="28" ToolTipService.ToolTip="置換モードの切り替え" Click="ToggleReplaceModeBtn_Click" />

                                        <TextBox x:Name="FindTextBox" Grid.Column="1" PlaceholderText="検索" Height="28" Padding="8,4" FontSize="12" TextChanged="FindTextBox_TextChanged" KeyDown="FindTextBox_KeyDown">
                                            <TextBox.Resources>
                                                <SolidColorBrush x:Key="TextControlBackground" Color="#252525" />
                                                <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#2d2d2d" />
                                                <SolidColorBrush x:Key="TextControlBorderBrush" Color="#333333" />
                                                <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#0078d4" />
                                            </TextBox.Resources>
                                        </TextBox>

                                        <TextBlock x:Name="FindCountTextBlock" Grid.Column="2" Text="0/0" FontSize="11" Foreground="#999999" VerticalAlignment="Center" Margin="4,0" />

                                        <Button Grid.Column="3" Content="&#xE112;" FontFamily="Segoe Fluent Icons" FontSize="12" Style="{StaticResource IconButtonStyle}" Width="28" Height="28" ToolTipService.ToolTip="前を検索 (Shift+Enter)" Click="FindPrev_Click" />
                                        <Button Grid.Column="4" Content="&#xE111;" FontFamily="Segoe Fluent Icons" FontSize="12" Style="{StaticResource IconButtonStyle}" Width="28" Height="28" ToolTipService.ToolTip="次を検索 (Enter)" Click="FindNext_Click" />
                                    </Grid>

                                    <Grid x:Name="ReplaceRow" Visibility="Collapsed" ColumnSpacing="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="28" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="28" />
                                        </Grid.ColumnDefinitions>

                                        <TextBox x:Name="ReplaceTextBox" Grid.Column="1" PlaceholderText="置換" Height="28" Padding="8,4" FontSize="12" KeyDown="ReplaceTextBox_KeyDown">
                                            <TextBox.Resources>
                                                <SolidColorBrush x:Key="TextControlBackground" Color="#252525" />
                                                <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#2d2d2d" />
                                                <SolidColorBrush x:Key="TextControlBorderBrush" Color="#333333" />
                                                <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#0078d4" />
                                            </TextBox.Resources>
                                        </TextBox>

                                        <Button Grid.Column="2" Content="&#xE8EA;" FontFamily="Segoe Fluent Icons" FontSize="12" Style="{StaticResource IconButtonStyle}" Width="28" Height="28" ToolTipService.ToolTip="置換 (Enter)" Click="Replace_Click" />
                                        <Button Grid.Column="3" Content="&#xEA5E;" FontFamily="Segoe Fluent Icons" FontSize="12" Style="{StaticResource IconButtonStyle}" Width="28" Height="28" ToolTipService.ToolTip="すべて置換" Click="ReplaceAll_Click" />
                                     </Grid>

                                    <TextBlock x:Name="FindStatusTextBlock" Foreground="#FF6B6B" FontSize="11" Visibility="Collapsed" Margin="32,0,0,0"/>
                                </StackPanel>
                            </Border>
                        </Canvas>
                        </Grid>

                    <Grid Grid.Row="2" Height="36" Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0" Spacing="12">
                            <TextBlock 
                                x:Name="CharCountTextBlock"
                                Text="0 characters"
                                VerticalAlignment="Center"
                                FontSize="11.5"
                                Foreground="#666666"
                                TextTrimming="CharacterEllipsis" />
                            
                            <!-- タグ表示領域 -->
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0" Spacing="2">
                            <ToggleButton x:Name="FormatBoldBtn" Content="&#xE19B;" Style="{StaticResource IconToggleButtonStyle}" AllowFocusOnInteraction="False" ToolTipService.ToolTip="太字 (Ctrl+B)" Click="FormatBold_Click" />
                            <ToggleButton x:Name="FormatItalicBtn" Content="&#xE199;" Style="{StaticResource IconToggleButtonStyle}" AllowFocusOnInteraction="False" ToolTipService.ToolTip="斜体 (Ctrl+I)" Click="FormatItalic_Click" />
                            <ToggleButton x:Name="FormatUnderlineBtn" Content="&#xE19A;" Style="{StaticResource IconToggleButtonStyle}" AllowFocusOnInteraction="False" ToolTipService.ToolTip="下線 (Ctrl+U)" Click="FormatUnderline_Click" />
                            <ToggleButton x:Name="FormatStrikethroughBtn" Content="&#xEDE0;" Style="{StaticResource IconToggleButtonStyle}" AllowFocusOnInteraction="False" ToolTipService.ToolTip="取り消し線 (Ctrl+Shift+S)" Click="FormatStrikethrough_Click" />
                            <ToggleButton x:Name="FormatHighlightBtn" Content="&#xE7E6;" Style="{StaticResource IconToggleButtonStyle}" AllowFocusOnInteraction="False" ToolTipService.ToolTip="ハイライト (Ctrl+Shift+H)" Click="FormatHighlight_Click" />
                            
                            <ToggleButton x:Name="FormatBulletListBtn" Content="&#xE8FD;" Style="{StaticResource IconToggleButtonStyle}" AllowFocusOnInteraction="False" ToolTipService.ToolTip="箇条書き (Ctrl+Shift+L)" Click="FormatBulletList_Click" />
                            <ToggleButton x:Name="FormatNumberListBtn" Content="&#xF146;" Style="{StaticResource IconToggleButtonStyle}" AllowFocusOnInteraction="False" ToolTipService.ToolTip="番号付きリスト (Ctrl+Shift+N)" Click="FormatNumberList_Click" />

                            <Button x:Name="FormatTableBtn" Content="&#xF232;" Style="{StaticResource IconButtonStyle}" AllowFocusOnInteraction="False" ToolTipService.ToolTip="テーブルの挿入">
                                <Button.Flyout>
                                    <Flyout x:Name="InsertTableFlyout">
                                        <Flyout.FlyoutPresenterStyle>
                                            <Style TargetType="FlyoutPresenter">
                                                <Setter Property="Background" Value="{StaticResource FlyoutBackgroundBrush}" />
                                                <Setter Property="BorderBrush" Value="#333333" />
                                                <Setter Property="BorderThickness" Value="1" />
                                                <Setter Property="CornerRadius" Value="8" />
                                                <Setter Property="Padding" Value="12" />
                                            </Style>
                                        </Flyout.FlyoutPresenterStyle>
                                        <StackPanel Spacing="8" Width="160">
                                            <TextBlock Text="テーブルの挿入" FontSize="12" FontWeight="SemiBold" Foreground="#ffffff" />
                                            <Grid ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0" Spacing="2">
                                                    <TextBlock Text="行数" FontSize="11" Foreground="#999999" />
                                                    <ComboBox x:Name="TableRowsComboBox" SelectedIndex="2" Height="28" Padding="8,0,24,0" HorizontalAlignment="Stretch" BorderThickness="1" BorderBrush="#333333" Background="#252525" CornerRadius="4">
                                                        <x:String>1</x:String>
                                                        <x:String>2</x:String>
                                                        <x:String>3</x:String>
                                                        <x:String>4</x:String>
                                                        <x:String>5</x:String>
                                                        <x:String>6</x:String>
                                                        <x:String>7</x:String>
                                                        <x:String>8</x:String>
                                                        <x:String>9</x:String>
                                                        <x:String>10</x:String>
                                                    </ComboBox>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1" Spacing="2">
                                                    <TextBlock Text="列数" FontSize="11" Foreground="#999999" />
                                                    <ComboBox x:Name="TableColsComboBox" SelectedIndex="2" Height="28" Padding="8,0,24,0" HorizontalAlignment="Stretch" BorderThickness="1" BorderBrush="#333333" Background="#252525" CornerRadius="4">
                                                        <x:String>1</x:String>
                                                        <x:String>2</x:String>
                                                        <x:String>3</x:String>
                                                        <x:String>4</x:String>
                                                        <x:String>5</x:String>
                                                        <x:String>6</x:String>
                                                        <x:String>7</x:String>
                                                        <x:String>8</x:String>
                                                        <x:String>9</x:String>
                                                        <x:String>10</x:String>
                                                    </ComboBox>
                                                </StackPanel>
                                            </Grid>
                                            <Button Content="挿入" HorizontalAlignment="Stretch" Height="28" Click="InsertTableConfirm_Click" CornerRadius="4">
                                                <Button.Resources>
                                                    <SolidColorBrush x:Key="ButtonBackground" Color="#0078d4" />
                                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#1084da" />
                                                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#005a9e" />
                                                    <SolidColorBrush x:Key="ButtonForeground" Color="#ffffff" />
                                                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#ffffff" />
                                                    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#ffffff" />
                                                </Button.Resources>
                                            </Button>
                                        </StackPanel>
                                    </Flyout>
                                </Button.Flyout>
                            </Button>

                            <Border Width="1" Height="16" Background="#333333" Margin="4,0" />

                            <ToggleButton x:Name="FormatHeading1Btn" Content="H1" Style="{StaticResource IconToggleButtonStyle}" FontFamily="Georgia" FontSize="12" FontWeight="Bold" AllowFocusOnInteraction="False" ToolTipService.ToolTip="見出し 1 (Ctrl+1)" Click="FormatHeading1_Click" />
                            <ToggleButton x:Name="FormatHeading2Btn" Content="H2" Style="{StaticResource IconToggleButtonStyle}" FontFamily="Georgia" FontSize="12" FontWeight="Bold" AllowFocusOnInteraction="False" ToolTipService.ToolTip="見出し 2 (Ctrl+2)" Click="FormatHeading2_Click" />

                            <Button Content="&#xE75C;" Style="{StaticResource IconButtonStyle}" AllowFocusOnInteraction="False" ToolTipService.ToolTip="装飾をクリア (Ctrl+Space)" Click="FormatClear_Click" />
                            
                            <Border Width="1" Height="16" Background="#333333" Margin="4,0" />

                            <Button x:Name="WordWrapButton" Content="T" Style="{StaticResource IconButtonStyle}" FontFamily="Georgia" FontSize="16" FontWeight="Normal" ToolTipService.ToolTip="右端折り返し切り替え" Click="WordWrapButton_Click" />
                        </StackPanel>
                    </Grid>
                </Grid>
                    </SplitView.Content>
                </SplitView>
            </SplitView.Content>
        </SplitView>

        <!-- AIリライトダイアログのオーバーレイ -->
        <Grid x:Name="AiRewriteDialogOverlay" Grid.RowSpan="3" Background="#40000000" Visibility="Collapsed" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Grid.Resources>
                <!-- アクリル透過背景ブラシ -->
                <AcrylicBrush x:Key="DialogBgBrush"
                              TintColor="#1f1f1f"
                              TintOpacity="0.55"
                              FallbackColor="#1f1f1f" />
                <SolidColorBrush x:Key="DialogInputBgBrush" Color="#121212" Opacity="0.40" />
            </Grid.Resources>
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="550" Background="{StaticResource DialogBgBrush}" CornerRadius="12" BorderThickness="1" BorderBrush="#2d2d2d" Padding="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" /> <!-- ヘッダー -->
                    <RowDefinition Height="*" />    <!-- メインテキストボックス -->
                    <RowDefinition Height="Auto" /> <!-- 調整用入力枠 (折りたたみ式) -->
                    <RowDefinition Height="Auto" /> <!-- フッターボタン群 -->
                </Grid.RowDefinitions>

                <!-- ヘッダー -->
                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="AI により生成" FontWeight="SemiBold" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center" />
                        <TextBlock x:Name="AiRewriteDialogStatusText" Text="" FontSize="11" Foreground="#999999" VerticalAlignment="Center" />
                    </StackPanel>
                    <!-- 閉じるボタン -->
                    <Button Grid.Column="2" Content="&#xE10A;" FontFamily="Segoe Fluent Icons" Style="{StaticResource IconButtonStyle}" Width="28" Height="28" FontSize="12" Click="AiRewriteDialogClose_Click" CornerRadius="4" />
                </Grid>

                <!-- テキストボックス -->
                <TextBox Grid.Row="1" x:Name="AiRewriteResultTextBox" Height="220" AcceptsReturn="True" TextWrapping="Wrap" ScrollViewer.VerticalScrollBarVisibility="Auto" Background="{StaticResource DialogInputBgBrush}" Foreground="#ffffff" BorderThickness="1" BorderBrush="#333333" CornerRadius="8" Padding="12" FontSize="13">
                    <TextBox.Resources>
                        <SolidColorBrush x:Key="TextControlBackground" Color="#121212" Opacity="0.40" />
                        <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#121212" Opacity="0.55" />
                        <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#121212" Opacity="0.40" />
                        <SolidColorBrush x:Key="TextControlForeground" Color="#ffffff" />
                        <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="#ffffff" />
                        <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#ffffff" />
                        <SolidColorBrush x:Key="TextControlBorderBrush" Color="#333333" />
                        <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#444444" />
                        <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#0078d4" />
                    </TextBox.Resources>
                </TextBox>

                <!-- 調整指示入力枠 (デフォルトは非表示) -->
                <StackPanel Grid.Row="2" x:Name="AiRewriteAdjustPanel" Margin="0,12,0,0" Spacing="6" Visibility="Collapsed">
                    <TextBlock Text="追加の指示・変更内容を入力してください:" FontSize="11" Foreground="#999999" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="AiRewriteAdjustInput" Height="28" PlaceholderText="例: もっと短く、箇条書きにして、など" FontSize="12" Background="{StaticResource DialogInputBgBrush}" BorderThickness="1" BorderBrush="#333333" CornerRadius="4" KeyDown="AiRewriteAdjustInput_KeyDown">
                            <TextBox.Resources>
                                <SolidColorBrush x:Key="TextControlBackground" Color="#121212" Opacity="0.40" />
                                <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#121212" Opacity="0.55" />
                                <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#121212" Opacity="0.40" />
                                <SolidColorBrush x:Key="TextControlForeground" Color="#ffffff" />
                                <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="#ffffff" />
                                <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#ffffff" />
                                <SolidColorBrush x:Key="TextControlBorderBrush" Color="#333333" />
                                <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#444444" />
                                <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#0078d4" />
                            </TextBox.Resources>
                        </TextBox>
                        <Button Grid.Column="1" Content="適用" Height="28" Padding="12,0" Click="AiRewriteAdjustSubmit_Click" CornerRadius="4">
                            <Button.Resources>
                                <SolidColorBrush x:Key="ButtonBackground" Color="#0078d4" />
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#1084da" />
                                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#005a9e" />
                                <SolidColorBrush x:Key="ButtonForeground" Color="#ffffff" />
                            </Button.Resources>
                        </Button>
                    </Grid>
                </StackPanel>

                <!-- フッターボタン -->
                <Grid Grid.Row="3" Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                        <!-- 置換 -->
                        <Button x:Name="AiRewriteReplaceButton" Click="AiRewriteReplace_Click" CornerRadius="4" Padding="12,6" Height="32">
                            <Button.Resources>
                                <SolidColorBrush x:Key="ButtonBackground" Color="#0078d4" />
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#1084da" />
                                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#005a9e" />
                                <SolidColorBrush x:Key="ButtonForeground" Color="#ffffff" />
                            </Button.Resources>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="&#xE105;" FontFamily="Segoe Fluent Icons" VerticalAlignment="Center" FontSize="12" />
                                <TextBlock Text="置換" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="12" />
                            </StackPanel>
                        </Button>

                        <!-- 調整 -->
                        <Button x:Name="AiRewriteAdjustButton" Click="AiRewriteAdjust_Click" CornerRadius="4" Padding="12,6" Height="32" Background="Transparent" BorderThickness="1" BorderBrush="#333333">
                            <Button.Resources>
                                <SolidColorBrush x:Key="ButtonBackground" Color="Transparent" />
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="White" Opacity="0.08" />
                                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="White" Opacity="0.14" />
                                <SolidColorBrush x:Key="ButtonForeground" Color="#ffffff" />
                                <SolidColorBrush x:Key="ButtonBorderBrush" Color="#333333" />
                                <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#444444" />
                            </Button.Resources>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="&#xE70F;" FontFamily="Segoe Fluent Icons" VerticalAlignment="Center" FontSize="12" />
                                <TextBlock Text="調整" VerticalAlignment="Center" FontSize="12" />
                            </StackPanel>
                        </Button>

                        <!-- 再生成 -->
                        <Button x:Name="AiRewriteRegenButton" Click="AiRewriteRegen_Click" CornerRadius="4" Width="32" Height="32" Padding="0" ToolTipService.ToolTip="再生成" Background="Transparent" BorderThickness="1" BorderBrush="#333333">
                            <Button.Resources>
                                <SolidColorBrush x:Key="ButtonBackground" Color="Transparent" />
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="White" Opacity="0.08" />
                                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="White" Opacity="0.14" />
                                <SolidColorBrush x:Key="ButtonForeground" Color="#ffffff" />
                                <SolidColorBrush x:Key="ButtonBorderBrush" Color="#333333" />
                                <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#444444" />
                            </Button.Resources>
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe Fluent Icons" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Button>
                    </StackPanel>

                    <!-- 生成停止 -->
                    <Button Grid.Column="2" x:Name="AiRewriteStopButton" Click="AiRewriteStop_Click" CornerRadius="4" Padding="12,6" Height="32" Background="#4c1d24" BorderThickness="1" BorderBrush="#8b2635" Visibility="Collapsed">
                        <Button.Resources>
                            <SolidColorBrush x:Key="ButtonBackground" Color="#4c1d24" />
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#5d2630" />
                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#3a141b" />
                            <SolidColorBrush x:Key="ButtonForeground" Color="#ff6b6b" />
                            <SolidColorBrush x:Key="ButtonBorderBrush" Color="#8b2635" />
                        </Button.Resources>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="&#xE71A;" FontFamily="Segoe Fluent Icons" VerticalAlignment="Center" FontSize="12" />
                            <TextBlock Text="生成を停止" VerticalAlignment="Center" FontSize="12" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>
        </Grid>

        <!-- AIで実行ダイアログのオーバーレイ -->
        <Grid x:Name="AiRunDialogOverlay" Grid.RowSpan="3" Background="#40000000" Visibility="Collapsed" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Grid.Resources>
                <!-- アクリル透過背景ブラシ -->
                <AcrylicBrush x:Key="DialogBgBrush"
                              TintColor="#1f1f1f"
                              TintOpacity="0.55"
                              FallbackColor="#1f1f1f" />
                <SolidColorBrush x:Key="DialogInputBgBrush" Color="#121212" Opacity="0.40" />
            </Grid.Resources>
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="550" Background="{StaticResource DialogBgBrush}" CornerRadius="12" BorderThickness="1" BorderBrush="#2d2d2d" Padding="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" /> <!-- ヘッダー -->
                    <RowDefinition Height="Auto" /> <!-- プロンプト入力 -->
                    <RowDefinition Height="*" />    <!-- メインテキストボックス（結果） -->
                    <RowDefinition Height="Auto" /> <!-- フッターボタン群 -->
                </Grid.RowDefinitions>

                <!-- ヘッダー -->
                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="AI で実行" FontWeight="SemiBold" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center" />
                        <TextBlock x:Name="AiRunDialogStatusText" Text="" FontSize="11" Foreground="#999999" VerticalAlignment="Center" />
                    </StackPanel>
                    <!-- 閉じるボタン -->
                    <Button Grid.Column="2" Content="&#xE10A;" FontFamily="Segoe Fluent Icons" Style="{StaticResource IconButtonStyle}" Width="28" Height="28" FontSize="12" Click="AiRunDialogClose_Click" CornerRadius="4" />
                </Grid>

                <!-- プロンプト入力 -->
                <Grid Grid.Row="1" Margin="0,0,0,12" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" x:Name="AiRunPromptInputTextBox" Height="60" AcceptsReturn="True" TextWrapping="Wrap" PlaceholderText="AIへの指示を入力してください（例：日本語に翻訳して、箇条書きでまとめて、など）" FontSize="12" Background="{StaticResource DialogInputBgBrush}" Foreground="#ffffff" BorderThickness="1" BorderBrush="#333333" CornerRadius="6" KeyDown="AiRunPromptInputTextBox_KeyDown">
                        <TextBox.Resources>
                            <SolidColorBrush x:Key="TextControlBackground" Color="#121212" Opacity="0.40" />
                            <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#121212" Opacity="0.55" />
                            <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#121212" Opacity="0.40" />
                            <SolidColorBrush x:Key="TextControlForeground" Color="#ffffff" />
                            <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="#ffffff" />
                            <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#ffffff" />
                            <SolidColorBrush x:Key="TextControlBorderBrush" Color="#333333" />
                            <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#444444" />
                            <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#0078d4" />
                        </TextBox.Resources>
                    </TextBox>
                    <Button Grid.Column="1" x:Name="AiRunExecuteButton" Content="実行" Height="60" Padding="16,0" Click="AiRunExecuteButton_Click" CornerRadius="6" VerticalAlignment="Stretch">
                        <Button.Resources>
                            <SolidColorBrush x:Key="ButtonBackground" Color="#0078d4" />
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#1084da" />
                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#005a9e" />
                            <SolidColorBrush x:Key="ButtonForeground" Color="#ffffff" />
                        </Button.Resources>
                    </Button>
                </Grid>

                <!-- テキストボックス (結果) -->
                <TextBox Grid.Row="2" x:Name="AiRunResultTextBox" Height="200" AcceptsReturn="True" TextWrapping="Wrap" ScrollViewer.VerticalScrollBarVisibility="Auto" Background="{StaticResource DialogInputBgBrush}" Foreground="#ffffff" BorderThickness="1" BorderBrush="#333333" CornerRadius="8" Padding="12" FontSize="13">
                    <TextBox.Resources>
                        <SolidColorBrush x:Key="TextControlBackground" Color="#121212" Opacity="0.40" />
                        <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#121212" Opacity="0.55" />
                        <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#121212" Opacity="0.40" />
                        <SolidColorBrush x:Key="TextControlForeground" Color="#ffffff" />
                        <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="#ffffff" />
                        <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#ffffff" />
                        <SolidColorBrush x:Key="TextControlBorderBrush" Color="#333333" />
                        <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#444444" />
                        <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#0078d4" />
                    </TextBox.Resources>
                </TextBox>

                <!-- フッターボタン -->
                <Grid Grid.Row="3" Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                        <!-- 置換 -->
                        <Button x:Name="AiRunReplaceButton" Click="AiRunReplace_Click" CornerRadius="4" Padding="12,6" Height="32" IsEnabled="False">
                            <Button.Resources>
                                <SolidColorBrush x:Key="ButtonBackground" Color="#0078d4" />
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#1084da" />
                                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#005a9e" />
                                <SolidColorBrush x:Key="ButtonForeground" Color="#ffffff" />
                            </Button.Resources>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock x:Name="AiRunReplaceIcon" Text="&#xE105;" FontFamily="Segoe Fluent Icons" VerticalAlignment="Center" FontSize="12" />
                                <TextBlock x:Name="AiRunReplaceText" Text="置換" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="12" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- 生成停止 -->
                    <Button Grid.Column="2" x:Name="AiRunStopButton" Click="AiRunStop_Click" CornerRadius="4" Padding="12,6" Height="32" Background="#4c1d24" BorderThickness="1" BorderBrush="#8b2635" Visibility="Collapsed">
                        <Button.Resources>
                            <SolidColorBrush x:Key="ButtonBackground" Color="#4c1d24" />
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#5d2630" />
                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#3a141b" />
                            <SolidColorBrush x:Key="ButtonForeground" Color="#ff6b6b" />
                            <SolidColorBrush x:Key="ButtonBorderBrush" Color="#8b2635" />
                        </Button.Resources>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="&#xE71A;" FontFamily="Segoe Fluent Icons" VerticalAlignment="Center" FontSize="12" />
                            <TextBlock Text="生成を停止" VerticalAlignment="Center" FontSize="12" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>
        </Grid>

        <!-- AIタスク生成ダイアログのオーバーレイ -->
        <Grid x:Name="AiTaskGenDialogOverlay" Grid.RowSpan="3" Background="#40000000" Visibility="Collapsed" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Grid.Resources>
                <!-- アクリル透過背景ブラシ -->
                <AcrylicBrush x:Key="DialogBgBrush"
                              TintColor="#1f1f1f"
                              TintOpacity="0.55"
                              FallbackColor="#1f1f1f" />
                <SolidColorBrush x:Key="DialogInputBgBrush" Color="#121212" Opacity="0.40" />
            </Grid.Resources>
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="550" Background="{StaticResource DialogBgBrush}" CornerRadius="12" BorderThickness="1" BorderBrush="#2d2d2d" Padding="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" /> <!-- ヘッダー -->
                    <RowDefinition Height="*" />    <!-- プレビューリスト -->
                    <RowDefinition Height="Auto" /> <!-- フッターボタン群 -->
                </Grid.RowDefinitions>

                <!-- ヘッダー -->
                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="AIタスク自動作成" FontWeight="SemiBold" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center" />
                        <TextBlock x:Name="AiTaskGenDialogStatusText" Text="" FontSize="11" Foreground="#999999" VerticalAlignment="Center" />
                    </StackPanel>
                    <!-- 閉じるボタン -->
                    <Button Grid.Column="2" Content="&#xE10A;" FontFamily="Segoe Fluent Icons" Style="{StaticResource IconButtonStyle}" Width="28" Height="28" FontSize="12" Click="AiTaskGenDialogClose_Click" CornerRadius="4" />
                </Grid>

                <!-- プレビューリスト -->
                <ListView Grid.Row="1" x:Name="AiTaskGenPreviewListView" Height="240" Background="{StaticResource DialogInputBgBrush}" BorderThickness="1" BorderBrush="#333333" CornerRadius="8" Padding="6" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:TaskPreviewItem">
                            <Grid Padding="4,2" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" IsChecked="{x:Bind IsSelected, Mode=TwoWay}" MinWidth="32" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1" Text="{x:Bind Title, Mode=TwoWay}" Foreground="#ffffff" FontSize="13" VerticalAlignment="Center" BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center">
                                    <TextBox.Resources>
                                        <SolidColorBrush x:Key="TextControlBackground" Color="Transparent" />
                                        <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent" />
                                        <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent" />
                                        <SolidColorBrush x:Key="TextControlForeground" Color="#ffffff" />
                                        <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="#ffffff" />
                                        <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#ffffff" />
                                    </TextBox.Resources>
                                </TextBox>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- フッターボタン -->
                <Grid Grid.Row="2" Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                        <!-- タスク確定登録 -->
                        <Button x:Name="AiTaskGenConfirmButton" Click="AiTaskGenConfirm_Click" CornerRadius="4" Padding="12,6" Height="32" IsEnabled="False">
                            <Button.Resources>
                                <SolidColorBrush x:Key="ButtonBackground" Color="#0078d4" />
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#1084da" />
                                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#005a9e" />
                                <SolidColorBrush x:Key="ButtonForeground" Color="#ffffff" />
                            </Button.Resources>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="&#xE105;" FontFamily="Segoe Fluent Icons" VerticalAlignment="Center" FontSize="12" />
                                <TextBlock Text="タスクを登録" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="12" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- 生成停止 -->
                    <Button Grid.Column="2" x:Name="AiTaskGenStopButton" Click="AiTaskGenStop_Click" CornerRadius="4" Padding="12,6" Height="32" Background="#4c1d24" BorderThickness="1" BorderBrush="#8b2635" Visibility="Collapsed">
                        <Button.Resources>
                            <SolidColorBrush x:Key="ButtonBackground" Color="#4c1d24" />
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#5d2630" />
                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#3a141b" />
                            <SolidColorBrush x:Key="ButtonForeground" Color="#ff6b6b" />
                            <SolidColorBrush x:Key="ButtonBorderBrush" Color="#8b2635" />
                        </Button.Resources>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="&#xE71A;" FontFamily="Segoe Fluent Icons" VerticalAlignment="Center" FontSize="12" />
                            <TextBlock Text="生成を停止" VerticalAlignment="Center" FontSize="12" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
