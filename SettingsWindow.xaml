<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="sumi.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:sumi"
    Title="環境設定">

    <Window.SystemBackdrop>
        <DesktopAcrylicBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" Background="#99141414">
        <Grid.Resources>
            <!-- テキスト入力コントロールのフォーカス枠線を上下左右均等（1px）に統一する設定 -->
            <Thickness x:Key="TextControlBorderThemeThickness">1</Thickness>
            <Thickness x:Key="TextControlBorderThemeThicknessFocused">1</Thickness>
            <!-- オプションカードの半透明背景 -->
            <SolidColorBrush x:Key="CardBackgroundBrush" Color="#141414" Opacity="0.60" />
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- タイトルバー -->
            <RowDefinition Height="*" />    <!-- メインコンテンツ -->
        </Grid.RowDefinitions>

        <!-- 1. カスタムタイトルバー -->
        <Grid Grid.Row="0" Height="36" BorderBrush="#2d2d2d" BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />    <!-- ドラッグ領域 (タイトル) -->
                <ColumnDefinition Width="Auto" /> <!-- 右側システムボタン用プレースホルダー -->
            </Grid.ColumnDefinitions>

            <!-- ドラッグ検出領域 -->
            <Grid Grid.Column="0" x:Name="TitleDragRegion" Background="Transparent">
                <TextBlock Text="環境設定" VerticalAlignment="Center" Margin="16,0,0,0" FontSize="12" Foreground="#ffffff" FontWeight="SemiBold" />
            </Grid>

            <!-- システムボタン（最小化・最大化・閉じる）用のスペースを確保 -->
            <Border Grid.Column="1" Width="140" Background="Transparent" />
        </Grid>

        <!-- 2. 設定エリア (2カラム) -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150" /> <!-- 左ナビゲーション -->
                <ColumnDefinition Width="1" />   <!-- 区切り線 -->
                <ColumnDefinition Width="*" />   <!-- 右コンテンツ -->
            </Grid.ColumnDefinitions>

            <!-- 左ナビゲーション -->
            <Grid Grid.Column="0" Background="#00000000" Padding="2,8,4,8">
                <StackPanel Spacing="4">
                    <!-- Editor -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border x:Name="NavEditorIndicator" Grid.Column="0" Width="3" Height="16" Background="#0078d4" CornerRadius="1.5" VerticalAlignment="Center" Visibility="Visible" />
                        <Button x:Name="NavEditorButton" Grid.Column="1" Click="NavButton_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Height="40" Padding="10,0" Background="Transparent" BorderThickness="0" CornerRadius="6" Margin="4,0,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE8D2;" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="#ffffff" />
                                <TextBlock Text="Editor" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Window -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border x:Name="NavWindowIndicator" Grid.Column="0" Width="3" Height="16" Background="#0078d4" CornerRadius="1.5" VerticalAlignment="Center" Visibility="Collapsed" />
                        <Button x:Name="NavWindowButton" Grid.Column="1" Click="NavButton_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Height="40" Padding="10,0" Background="Transparent" BorderThickness="0" CornerRadius="6" Margin="4,0,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE7B5;" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="#ffffff" />
                                <TextBlock Text="Window" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- System -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border x:Name="NavSystemIndicator" Grid.Column="0" Width="3" Height="16" Background="#0078d4" CornerRadius="1.5" VerticalAlignment="Center" Visibility="Collapsed" />
                        <Button x:Name="NavSystemButton" Grid.Column="1" Click="NavButton_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Height="40" Padding="10,0" Background="Transparent" BorderThickness="0" CornerRadius="6" Margin="4,0,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE765;" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="#ffffff" />
                                <TextBlock Text="System" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- AI -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border x:Name="NavAiIndicator" Grid.Column="0" Width="3" Height="16" Background="#0078d4" CornerRadius="1.5" VerticalAlignment="Center" Visibility="Collapsed" />
                        <Button x:Name="NavAiButton" Grid.Column="1" Click="NavButton_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Height="40" Padding="10,0" Background="Transparent" BorderThickness="0" CornerRadius="6" Margin="4,0,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE9D9;" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="#ffffff" />
                                <TextBlock Text="AI" FontSize="13" Foreground="#ffffff" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Grid>

            <!-- 区切り線 -->
            <Border Grid.Column="1" Background="#2d2d2d" />

            <!-- 右コンテンツ -->
            <Grid Grid.Column="2" Padding="20,16">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid>
                        <!-- Editor Settings -->
                        <StackPanel x:Name="EditorSettingsPanel" Spacing="12" Visibility="Visible">
                            <TextBlock Text="Editor Settings" FontSize="18" FontWeight="Bold" Foreground="#ffffff" Margin="0,0,0,8" />
                            
                            <!-- Font Family -->
                            <Grid Padding="16,12" Background="{StaticResource CardBackgroundBrush}" BorderBrush="#2d2d2d" BorderThickness="1" CornerRadius="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center" Spacing="2">
                                    <TextBlock Text="Font Family" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff" />
                                    <TextBlock Text="エディタのフォントを設定します。" FontSize="12" Foreground="#888888" />
                                </StackPanel>
                                <ComboBox Grid.Column="1" x:Name="FontComboBox" Width="160" Height="32" SelectionChanged="FontComboBox_SelectionChanged" BorderThickness="1" BorderBrush="#333333" Background="#252525" CornerRadius="4">
                                    <x:String>Noto Sans JP</x:String>
                                    <x:String>Yu Gothic UI</x:String>
                                    <x:String>Segoe UI</x:String>
                                    <x:String>Consolas</x:String>
                                    <x:String>Georgia</x:String>
                                </ComboBox>
                            </Grid>

                            <!-- Font Weight -->
                            <Grid Padding="16,12" Background="{StaticResource CardBackgroundBrush}" BorderBrush="#2d2d2d" BorderThickness="1" CornerRadius="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center" Spacing="2">
                                    <TextBlock Text="Font Weight" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff" />
                                    <TextBlock Text="文字の太さを設定します。" FontSize="12" Foreground="#888888" />
                                </StackPanel>
                                <ComboBox Grid.Column="1" x:Name="FontWeightComboBox" Width="160" Height="32" SelectionChanged="FontWeightComboBox_SelectionChanged" BorderThickness="1" BorderBrush="#333333" Background="#252525" CornerRadius="4">
                                    <x:String>Light</x:String>
                                    <x:String>Normal</x:String>
                                    <x:String>Medium</x:String>
                                    <x:String>SemiBold</x:String>
                                    <x:String>Bold</x:String>
                                </ComboBox>
                            </Grid>

                            <!-- Font Size -->
                            <Grid Padding="16,12" Background="{StaticResource CardBackgroundBrush}" BorderBrush="#2d2d2d" BorderThickness="1" CornerRadius="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center" Spacing="2">
                                    <TextBlock Text="Font Size" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff" />
                                    <TextBlock Text="文字のサイズを設定します。" FontSize="12" Foreground="#888888" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <Button x:Name="FontSizeDecreaseButton" Content="&#xE108;" FontFamily="Segoe Fluent Icons" Width="32" Height="32" FontSize="10" Click="FontSizeDecreaseButton_Click" Background="#252525" BorderBrush="#333333" BorderThickness="1" CornerRadius="4"/>
                                    <Slider x:Name="FontSizeSlider" Minimum="10" Maximum="36" StepFrequency="0.5" Width="120" ValueChanged="FontSizeSlider_ValueChanged" VerticalAlignment="Center" />
                                    <Button x:Name="FontSizeIncreaseButton" Content="&#xE109;" FontFamily="Segoe Fluent Icons" Width="32" Height="32" FontSize="10" Click="FontSizeIncreaseButton_Click" Background="#252525" BorderBrush="#333333" BorderThickness="1" CornerRadius="4"/>
                                    <TextBlock x:Name="FontSizeValueText" Text="14.0" FontSize="13" Foreground="#cccccc" Width="32" TextAlignment="Right" VerticalAlignment="Center" />
                                </StackPanel>
                            </Grid>

                            <!-- Line Spacing -->
                            <Grid Padding="16,12" Background="{StaticResource CardBackgroundBrush}" BorderBrush="#2d2d2d" BorderThickness="1" CornerRadius="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center" Spacing="2">
                                    <TextBlock Text="Line Spacing" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff" />
                                    <TextBlock Text="行間を設定します。" FontSize="12" Foreground="#888888" />
                                </StackPanel>
                                <ComboBox Grid.Column="1" x:Name="LineSpacingComboBox" 
                                          Width="160" Height="32"
                                          IsEditable="True" 
                                          SelectionChanged="LineSpacingComboBox_SelectionChanged" 
                                          LostFocus="LineSpacingComboBox_LostFocus"
                                          BorderThickness="1" BorderBrush="#333333" Background="#252525" CornerRadius="4">
                                    <x:String>0.8</x:String>
                                    <x:String>0.85</x:String>
                                    <x:String>0.9</x:String>
                                    <x:String>0.95</x:String>
                                    <x:String>1.0</x:String>
                                </ComboBox>
                            </Grid>

                            <!-- Paragraph Spacing -->
                            <Grid Padding="16,12" Background="{StaticResource CardBackgroundBrush}" BorderBrush="#2d2d2d" BorderThickness="1" CornerRadius="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center" Spacing="2">
                                    <TextBlock Text="Paragraph Spacing" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff" />
                                    <TextBlock Text="段落後のスペースを設定します。" FontSize="12" Foreground="#888888" />
                                </StackPanel>
                                <ComboBox Grid.Column="1" x:Name="ParagraphSpacingComboBox" 
                                          Width="160" Height="32"
                                          IsEditable="True" 
                                          SelectionChanged="ParagraphSpacingComboBox_SelectionChanged" 
                                          LostFocus="ParagraphSpacingComboBox_LostFocus"
                                          BorderThickness="1" BorderBrush="#333333" Background="#252525" CornerRadius="4">
                                    <x:String>0</x:String>
                                    <x:String>2</x:String>
                                    <x:String>4</x:String>
                                    <x:String>6</x:String>
                                    <x:String>8</x:String>
                                    <x:String>10</x:String>
                                    <x:String>12</x:String>
                                </ComboBox>
                            </Grid>
                        </StackPanel>

                        <!-- Window Settings -->
                        <StackPanel x:Name="WindowSettingsPanel" Spacing="12" Visibility="Collapsed">
                            <TextBlock Text="Window Settings" FontSize="18" FontWeight="Bold" Foreground="#ffffff" Margin="0,0,0,8" />

                            <!-- Opacity -->
                            <Grid Padding="16,12" Background="{StaticResource CardBackgroundBrush}" BorderBrush="#2d2d2d" BorderThickness="1" CornerRadius="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center" Spacing="2">
                                    <TextBlock Text="Opacity" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff" />
                                    <TextBlock Text="ウィンドウの不透明度を設定します。" FontSize="12" Foreground="#888888" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <Button x:Name="OpacityDecreaseButton" Content="&#xE108;" FontFamily="Segoe Fluent Icons" Width="32" Height="32" FontSize="10" Click="OpacityDecreaseButton_Click" Background="#252525" BorderBrush="#333333" BorderThickness="1" CornerRadius="4"/>
                                    <Slider x:Name="OpacitySlider" Minimum="0" Maximum="100" StepFrequency="1" Width="120" ValueChanged="OpacitySlider_ValueChanged" VerticalAlignment="Center" />
                                    <Button x:Name="OpacityIncreaseButton" Content="&#xE109;" FontFamily="Segoe Fluent Icons" Width="32" Height="32" FontSize="10" Click="OpacityIncreaseButton_Click" Background="#252525" BorderBrush="#333333" BorderThickness="1" CornerRadius="4"/>
                                    <TextBlock x:Name="OpacityValueText" Text="100%" FontSize="13" Foreground="#cccccc" Width="36" TextAlignment="Right" VerticalAlignment="Center" />
                                </StackPanel>
                            </Grid>

                            <!-- Show Delete Button -->
                            <Grid Padding="16,12" Background="{StaticResource CardBackgroundBrush}" BorderBrush="#2d2d2d" BorderThickness="1" CornerRadius="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center" Spacing="2">
                                    <TextBlock Text="Show Delete Button" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff" />
                                    <TextBlock Text="メモ一覧に削除ボタンを表示するかどうか設定します。" FontSize="12" Foreground="#888888" />
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1" x:Name="ShowDeleteButtonToggle" OnContent="" OffContent="" MinWidth="0" VerticalAlignment="Center" Toggled="ShowDeleteButtonToggle_Toggled" />
                            </Grid>

                            <!-- Recent Notes Count -->
                            <Grid Padding="16,12" Background="{StaticResource CardBackgroundBrush}" BorderBrush="#2d2d2d" BorderThickness="1" CornerRadius="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center" Spacing="2">
                                    <TextBlock Text="Recent Notes Count" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff" />
                                    <TextBlock Text="サイドバーに表示する「最近開いたメモ」の最大件数を設定します。" FontSize="12" Foreground="#888888" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <Button x:Name="RecentNotesCountDecreaseButton" Content="&#xE108;" FontFamily="Segoe Fluent Icons" Width="32" Height="32" FontSize="10" Click="RecentNotesCountDecreaseButton_Click" Background="#252525" BorderBrush="#333333" BorderThickness="1" CornerRadius="4"/>
                                    <Slider x:Name="RecentNotesCountSlider" Minimum="0" Maximum="10" StepFrequency="1" Width="120" ValueChanged="RecentNotesCountSlider_ValueChanged" VerticalAlignment="Center" />
                                    <Button x:Name="RecentNotesCountIncreaseButton" Content="&#xE109;" FontFamily="Segoe Fluent Icons" Width="32" Height="32" FontSize="10" Click="RecentNotesCountIncreaseButton_Click" Background="#252525" BorderBrush="#333333" BorderThickness="1" CornerRadius="4"/>
                                    <TextBlock x:Name="RecentNotesCountValueText" Text="5" FontSize="13" Foreground="#cccccc" Width="32" TextAlignment="Right" VerticalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <!-- System Settings -->
                        <StackPanel x:Name="SystemSettingsPanel" Spacing="12" Visibility="Collapsed">
                            <TextBlock Text="System Settings" FontSize="18" FontWeight="Bold" Foreground="#ffffff" Margin="0,0,0,8" />

                            <!-- Launch Hotkey -->
                            <Grid Padding="16,12" Background="{StaticResource CardBackgroundBrush}" BorderBrush="#2d2d2d" BorderThickness="1" CornerRadius="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center" Spacing="2">
                                    <TextBlock Text="Launch Hotkey" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff" />
                                    <TextBlock Text="アプリを表示・非表示にするグローバルショートカットキー。" FontSize="12" Foreground="#888888" />
                                </StackPanel>
                                <Button Grid.Column="1" x:Name="LaunchHotKeyButton" Width="140" Height="32" Content="None" Background="#252525" BorderBrush="#333333" BorderThickness="1" CornerRadius="4">
                                    <Button.Flyout>
                                        <Flyout x:Name="LaunchHotKeyFlyout" Opened="HotKeyFlyout_Opened" Closed="HotKeyFlyout_Closed">
                                            <StackPanel Spacing="8" Width="180">
                                                <TextBlock Text="キーの組み合わせを入力:" FontSize="12" Foreground="#cccccc" />
                                                <TextBox x:Name="LaunchHotKeyInput" Height="32" IsReadOnly="True" KeyDown="HotKeyInput_KeyDown" TextAlignment="Center" FontSize="13" VerticalContentAlignment="Center" Background="#252525" BorderBrush="#333333"/>
                                                <Grid ColumnSpacing="4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Button Grid.Column="0" Content="保存" Click="SaveLaunchHotKey_Click" HorizontalAlignment="Stretch" Height="28" Padding="0" FontSize="11" CornerRadius="4" />
                                                    <Button Grid.Column="1" Content="クリア" Click="ClearLaunchHotKey_Click" HorizontalAlignment="Stretch" Height="28" Padding="0" FontSize="11" CornerRadius="4" />
                                                    <Button Grid.Column="2" Content="閉じる" Click="CancelLaunchHotKey_Click" HorizontalAlignment="Stretch" Height="28" Padding="0" FontSize="11" CornerRadius="4" />
                                                </Grid>
                                            </StackPanel>
                                        </Flyout>
                                    </Button.Flyout>
                                </Button>
                            </Grid>

                            <!-- Quit Hotkey -->
                            <Grid Padding="16,12" Background="{StaticResource CardBackgroundBrush}" BorderBrush="#2d2d2d" BorderThickness="1" CornerRadius="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center" Spacing="2">
                                    <TextBlock Text="Quit Hotkey" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff" />
                                    <TextBlock Text="アプリを完全に終了するグローバルショートカットキー。" FontSize="12" Foreground="#888888" />
                                </StackPanel>
                                <Button Grid.Column="1" x:Name="QuitHotKeyButton" Width="140" Height="32" Content="None" Background="#252525" BorderBrush="#333333" BorderThickness="1" CornerRadius="4">
                                    <Button.Flyout>
                                        <Flyout x:Name="QuitHotKeyFlyout" Opened="HotKeyFlyout_Opened" Closed="HotKeyFlyout_Closed">
                                            <StackPanel Spacing="8" Width="180">
                                                <TextBlock Text="キーの組み合わせを入力:" FontSize="12" Foreground="#cccccc" />
                                                <TextBox x:Name="QuitHotKeyInput" Height="32" IsReadOnly="True" KeyDown="HotKeyInput_KeyDown" TextAlignment="Center" FontSize="13" VerticalContentAlignment="Center" Background="#252525" BorderBrush="#333333"/>
                                                <Grid ColumnSpacing="4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Button Grid.Column="0" Content="保存" Click="SaveQuitHotKey_Click" HorizontalAlignment="Stretch" Height="28" Padding="0" FontSize="11" CornerRadius="4" />
                                                    <Button Grid.Column="1" Content="クリア" Click="ClearQuitHotKey_Click" HorizontalAlignment="Stretch" Height="28" Padding="0" FontSize="11" CornerRadius="4" />
                                                    <Button Grid.Column="2" Content="閉じる" Click="CancelQuitHotKey_Click" HorizontalAlignment="Stretch" Height="28" Padding="0" FontSize="11" CornerRadius="4" />
                                                </Grid>
                                            </StackPanel>
                                        </Flyout>
                                    </Button.Flyout>
                                </Button>
                            </Grid>

                            <!-- Delete Note -->
                            <Grid Padding="16,12" Background="{StaticResource CardBackgroundBrush}" BorderBrush="#2d2d2d" BorderThickness="1" CornerRadius="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center" Spacing="2">
                                    <TextBlock Text="Delete Note" FontSize="14" FontWeight="SemiBold" Foreground="#ff453a" />
                                    <TextBlock Text="現在のメモを完全に削除します (Ctrl+D)。" FontSize="12" Foreground="#888888" />
                                </StackPanel>
                                <Button Grid.Column="1" x:Name="DeleteNoteButton" Content="削除" Click="DeleteNoteButton_Click" Background="#252525" Foreground="#ff453a" BorderBrush="#333333" BorderThickness="1" CornerRadius="4" Padding="16,4" />
                            </Grid>
                        </StackPanel>

                        <!-- AI Settings -->
                        <StackPanel x:Name="AiSettingsPanel" Spacing="12" Visibility="Collapsed">
                            <TextBlock Text="AI Settings" FontSize="18" FontWeight="Bold" Foreground="#ffffff" Margin="0,0,0,8" />

                            <!-- API Key -->
                            <Grid Padding="16,12" Background="{StaticResource CardBackgroundBrush}" BorderBrush="#2d2d2d" BorderThickness="1" CornerRadius="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="180" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center" Spacing="2">
                                    <TextBlock Text="API Key" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff" />
                                    <TextBlock Text="AI機能を利用するためのAPIキー。" FontSize="12" Foreground="#888888" />
                                </StackPanel>
                                <PasswordBox Grid.Column="1" x:Name="AiApiKeyBox" Height="32" PasswordChar="*" PasswordRevealMode="Peek" BorderThickness="1" BorderBrush="#333333" Background="#252525" CornerRadius="4" LostFocus="AiApiKeyBox_LostFocus" />
                            </Grid>

                            <!-- Model Name -->
                            <Grid Padding="16,12" Background="{StaticResource CardBackgroundBrush}" BorderBrush="#2d2d2d" BorderThickness="1" CornerRadius="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="180" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center" Spacing="2">
                                    <TextBlock Text="Model Name" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff" />
                                    <TextBlock Text="使用するAIモデル名を設定します。" FontSize="12" Foreground="#888888" />
                                </StackPanel>
                                <TextBox Grid.Column="1" x:Name="AiModelNameBox" Height="32" FontSize="13" BorderThickness="1" BorderBrush="#333333" Background="#252525" CornerRadius="4" LostFocus="AiModelNameBox_LostFocus" Padding="6,4" />
                            </Grid>

                            <!-- Temperature -->
                            <Grid Padding="16,12" Background="{StaticResource CardBackgroundBrush}" BorderBrush="#2d2d2d" BorderThickness="1" CornerRadius="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center" Spacing="2">
                                    <TextBlock Text="Temperature" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff" />
                                    <TextBlock Text="出力の多様性（創造性）を設定します。" FontSize="12" Foreground="#888888" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <Slider x:Name="AiTemperatureSlider" Minimum="0" Maximum="2" StepFrequency="0.1" Width="120" ValueChanged="AiTemperatureSlider_ValueChanged" VerticalAlignment="Center" />
                                    <TextBlock x:Name="AiTemperatureValueText" Text="0.7" FontSize="13" Foreground="#cccccc" Width="24" TextAlignment="Right" VerticalAlignment="Center" />
                                </StackPanel>
                            </Grid>

                            <!-- Max Tokens -->
                            <Grid Padding="16,12" Background="{StaticResource CardBackgroundBrush}" BorderBrush="#2d2d2d" BorderThickness="1" CornerRadius="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="100" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center" Spacing="2">
                                    <TextBlock Text="Max Tokens" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff" />
                                    <TextBlock Text="応答の最大トークン数を設定します。" FontSize="12" Foreground="#888888" />
                                </StackPanel>
                                <TextBox Grid.Column="1" x:Name="AiMaxTokensBox" Height="32" FontSize="13" BorderThickness="1" BorderBrush="#333333" Background="#252525" CornerRadius="4" LostFocus="AiMaxTokensBox_LostFocus" Padding="6,4" InputScope="Number" />
                            </Grid>

                            <!-- System Prompt -->
                            <StackPanel Padding="16,12" Background="{StaticResource CardBackgroundBrush}" BorderBrush="#2d2d2d" BorderThickness="1" CornerRadius="8" Spacing="8">
                                <TextBlock Text="System Prompt" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff" />
                                <TextBox x:Name="AiSystemPromptBox" Height="80" FontSize="12" TextWrapping="Wrap" AcceptsReturn="True" BorderThickness="1" BorderBrush="#333333" Background="#252525" CornerRadius="4" LostFocus="AiSystemPromptBox_LostFocus" Padding="8,6" />
                            </StackPanel>

                            <!-- AI Rewrite Prompts -->
                            <StackPanel Padding="16,12" Background="{StaticResource CardBackgroundBrush}" BorderBrush="#2d2d2d" BorderThickness="1" CornerRadius="8" Spacing="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="リライトプロンプト" FontSize="14" FontWeight="SemiBold" Foreground="#ffffff" VerticalAlignment="Center" />
                                    <Button Grid.Column="1" FontSize="12" Height="32" Padding="12,0" Click="AddAiPrompt_Click" CornerRadius="4" Background="#252525" BorderBrush="#333333" BorderThickness="1">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE710;" FontFamily="Segoe Fluent Icons" FontSize="12" />
                                            <TextBlock Text="追加" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                                <StackPanel x:Name="AiPromptsListPanel" Spacing="8" Margin="0,4,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>
